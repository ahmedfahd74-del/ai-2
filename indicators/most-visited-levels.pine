// ============================================================================
// MOST VISITED LEVELS - Automatic S/R from Price Frequency
// ============================================================================
// Version: 2.0 - MTF support + meaningful touch filtering
// ============================================================================

//@version=6
indicator("Most Visited Levels v2", overlay = true, max_lines_count = 20, max_labels_count = 20)

// --- Inputs ---

lookback    = input.int(500, "Lookback Bars", minval = 50, maxval = 5000, group = "Analysis")
numBins     = input.int(100, "Price Resolution (bins)", minval = 20, maxval = 500, group = "Analysis")
numLevels   = input.int(5, "Number of Levels", minval = 1, maxval = 10, group = "Analysis")
minDistance  = input.float(1.0, "Min Distance Between Levels (ATR mult)", minval = 0.1, group = "Analysis")
touchPower  = input.int(5, "Touch Power (min bounces at level)", minval = 1, maxval = 30, group = "Analysis", tooltip = "Minimum number of times price must BOUNCE off a level (not just pass through). Higher = stronger levels only.")
useMTF      = input.bool(false, "Use Fixed Timeframe (MTF)", group = "MTF", tooltip = "When enabled, levels are calculated from a fixed timeframe regardless of chart TF")
mtfTF       = input.timeframe("D", "Analysis Timeframe", group = "MTF", tooltip = "Timeframe to calculate levels from. Levels stay consistent across chart TFs.")

lineColor   = input.color(color.new(color.yellow, 0), "Line Color", group = "Visuals")
lineWidth   = input.int(2, "Line Width", minval = 1, maxval = 5, group = "Visuals")
lineStyle   = input.string("solid", "Line Style", options = ["solid", "dashed", "dotted"], group = "Visuals")
showLabels  = input.bool(true, "Show Price Labels", group = "Visuals")

// --- State Variables ---

var array<line>  drawnLines  = array.new_line()
var array<label> drawnLabels = array.new_label()

// --- Helper ---

getLineStyle(string style) =>
    switch style
        "dashed" => line.style_dashed
        "dotted" => line.style_dotted
        => line.style_solid

// --- Pre-calculate ta functions at top level (Pine v6 requirement) ---

float _rangeHigh = ta.highest(high, lookback)
float _rangeLow  = ta.lowest(low, lookback)
float _atrValue  = ta.atr(14)

// --- MTF data fetch (when MTF mode enabled) ---
// Fetch high/low/close arrays from the selected timeframe

[mtfHigh, mtfLow, mtfClose, mtfRangeH, mtfRangeL, mtfAtr] = request.security(syminfo.tickerid, mtfTF, [high, low, close, ta.highest(high, lookback), ta.lowest(low, lookback), ta.atr(14)], lookahead = barmerge.lookahead_off)

// --- Main Logic ---

if barstate.islast
    // Clean up
    if array.size(drawnLines) > 0
        for i = 0 to array.size(drawnLines) - 1
            line.delete(array.get(drawnLines, i))
        array.clear(drawnLines)

    if array.size(drawnLabels) > 0
        for i = 0 to array.size(drawnLabels) - 1
            label.delete(array.get(drawnLabels, i))
        array.clear(drawnLabels)

    // Select data source based on MTF setting
    float rangeHigh = useMTF ? mtfRangeH : _rangeHigh
    float rangeLow  = useMTF ? mtfRangeL : _rangeLow
    float atrVal    = useMTF ? mtfAtr : _atrValue
    int barsAvailable = math.min(lookback - 1, bar_index)
    float binSize   = (rangeHigh - rangeLow) / numBins

    if binSize > 0 and not na(rangeHigh) and not na(rangeLow)
        // --- Count BOUNCES per bin (not just pass-throughs) ---
        // A bounce = bar's low touches the bin AND close is above (support bounce)
        //         OR bar's high touches the bin AND close is below (resistance bounce)
        // This filters out bins where price just blows through without reacting.
        array<int> bounceCounts = array.new_int(numBins, 0)

        for i = 0 to barsAvailable
            float barH = high[i]
            float barL = low[i]
            float barC = close[i]
            float barO = open[i]

            // Find which bins the bar's low wick touches (potential support bounce)
            int lowBin = math.max(0, math.min(numBins - 1, int((barL - rangeLow) / binSize)))
            // Support bounce: low touches the bin but close is above it (price bounced up)
            float binTop = rangeLow + (lowBin + 1) * binSize
            if barC > binTop and barL <= binTop
                array.set(bounceCounts, lowBin, array.get(bounceCounts, lowBin) + 1)

            // Find which bins the bar's high wick touches (potential resistance bounce)
            int highBin = math.max(0, math.min(numBins - 1, int((barH - rangeLow) / binSize)))
            // Resistance bounce: high touches the bin but close is below it (price bounced down)
            float binBot = rangeLow + highBin * binSize
            if barC < binBot and barH >= binBot
                array.set(bounceCounts, highBin, array.get(bounceCounts, highBin) + 1)

            // Also count bars that open AND close on opposite sides of a bin (reversal through)
            int openBin = math.max(0, math.min(numBins - 1, int((barO - rangeLow) / binSize)))
            int closeBin = math.max(0, math.min(numBins - 1, int((barC - rangeLow) / binSize)))
            if openBin != closeBin
                // The boundary between them got a reaction
                int reactBin = math.min(openBin, closeBin)
                if reactBin >= 0 and reactBin < numBins
                    array.set(bounceCounts, reactBin, array.get(bounceCounts, reactBin) + 1)

        // Find top N levels
        float minDistPrice  = nz(atrVal, binSize) * minDistance
        array<float> levels = array.new_float()
        array<int>   counts = array.new_int()
        string       lStyle = getLineStyle(lineStyle)

        for lvl = 0 to numLevels - 1
            int maxCount = 0
            int maxBin   = -1
            for b = 0 to numBins - 1
                int cnt = array.get(bounceCounts, b)
                if cnt > maxCount
                    maxCount := cnt
                    maxBin   := b

            if maxBin == -1 or maxCount == 0
                break

            // Touch power filter: skip if not enough bounces
            if maxCount < touchPower
                break

            float levelPrice = rangeLow + (maxBin + 0.5) * binSize
            array.push(levels, levelPrice)
            array.push(counts, maxCount)

            // Zero out nearby bins
            int binsToZero = math.max(1, int(minDistPrice / binSize))
            int zeroStart  = math.max(0, maxBin - binsToZero)
            int zeroEnd    = math.min(numBins - 1, maxBin + binsToZero)
            for b = zeroStart to zeroEnd
                array.set(bounceCounts, b, 0)

        // Draw lines
        if array.size(levels) > 0
            for i = 0 to array.size(levels) - 1
                float lvlPrice = array.get(levels, i)
                int   lvlCount = array.get(counts, i)

                line newLine = line.new(bar_index - barsAvailable, lvlPrice, bar_index, lvlPrice, extend = extend.both, color = lineColor, width = lineWidth, style = lStyle)
                array.push(drawnLines, newLine)

                if showLabels
                    label newLabel = label.new(bar_index + 5, lvlPrice, str.tostring(lvlPrice, format.mintick) + " (" + str.tostring(lvlCount) + "x)", style = label.style_label_left, color = color.new(color.black, 60), textcolor = lineColor, size = size.small)
                    array.push(drawnLabels, newLabel)
