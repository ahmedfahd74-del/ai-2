// ============================================================================
// MOST VISITED LEVELS v5 - Cluster-Based S/R with Smart Coloring
// ============================================================================
// Collects pivot highs and lows from the analysis timeframe, clusters nearby
// pivots using ATR-based tolerance, ranks by recency-weighted count, and draws
// the top N clusters as horizontal lines. Levels are colored by Support/
// Resistance (relative to price) and scaled by strength (touch count).
// ============================================================================

//@version=6
indicator("Most Visited Levels v5", overlay = true, max_lines_count = 20, max_labels_count = 20)

// --- Inputs ---

lookback    = input.int(200, "Lookback Bars", minval = 20, maxval = 2000, group = "Analysis")
numLevels   = input.int(5, "Number of Levels", minval = 1, maxval = 10, group = "Analysis")
touchPower  = input.int(3, "Min Touches", minval = 1, maxval = 20, group = "Analysis", tooltip = "Min swing reversals at a level")
pivotLen    = input.int(3, "Pivot Strength", minval = 1, maxval = 10, group = "Analysis", tooltip = "Bars left/right for swing detection")
clusterATR  = input.float(0.5, "Cluster Width (ATR x)", minval = 0.1, maxval = 3.0, step = 0.1, group = "Analysis", tooltip = "How close pivots must be to count as same level")
minDistance  = input.float(1.5, "Min Distance Between Levels (ATR x)", minval = 0.1, step = 0.1, group = "Analysis")
analysisTF  = input.timeframe("D", "Analysis Timeframe", group = "Analysis")

// Color settings
useAutoColor    = input.bool(true, "Auto Color by S/R", group = "Visuals", tooltip = "Green below price (support), red above price (resistance). If off, uses single color.")
supportColor    = input.color(color.new(color.green, 0), "Support Color (below price)", group = "Visuals")
resistanceColor = input.color(color.new(color.red, 0), "Resistance Color (above price)", group = "Visuals")
singleColor     = input.color(color.new(color.yellow, 0), "Single Color (if auto off)", group = "Visuals")
useStrengthVisual = input.bool(true, "Scale Line by Strength", group = "Visuals", tooltip = "Stronger levels appear thicker and brighter")

lineWidth   = input.int(3, "Max Line Width", minval = 1, maxval = 5, group = "Visuals")
lineStyle   = input.string("solid", "Line Style", options = ["solid", "dashed", "dotted"], group = "Visuals")
showLabels  = input.bool(true, "Show Price Labels", group = "Visuals")
showStats   = input.bool(true, "Show Hit Rate Panel", group = "Visuals", tooltip = "Show hit rate tracking panel")
labelOffset = input.int(50, "Label Offset (bars right)", minval = 5, maxval = 200, group = "Visuals", tooltip = "How far to the right the price label sits from current bar")
labelSize   = input.string("small", "Label Size", options = ["tiny", "small", "normal", "large"], group = "Visuals")

// --- State ---

var array<line>  drawnLines  = array.new_line()
var array<label> drawnLabels = array.new_label()

// --- Hit Rate Tracking State ---

var array<float> historicalLevels = array.new_float()
var array<bool>  levelHit         = array.new_bool()
var array<int>   levelBar         = array.new_int()
var int          totalLevelsDrawn = 0
var int          totalLevelsHit   = 0

// --- Helpers ---

getLineStyle(string style) =>
    switch style
        "dashed" => line.style_dashed
        "dotted" => line.style_dotted
        => line.style_solid

getLabelSize(string sz) =>
    switch sz
        "tiny"   => size.tiny
        "normal" => size.normal
        "large"  => size.large
        => size.small

// --- MTF Data Collection ---

float tfHigh   = request.security(syminfo.tickerid, analysisTF, high[1], lookahead = barmerge.lookahead_on)
float tfLow    = request.security(syminfo.tickerid, analysisTF, low[1], lookahead = barmerge.lookahead_on)
float tfAtr    = request.security(syminfo.tickerid, analysisTF, ta.atr(14)[1], lookahead = barmerge.lookahead_on)
float tfRangeH = request.security(syminfo.tickerid, analysisTF, ta.highest(high, lookback)[1], lookahead = barmerge.lookahead_on)
float tfRangeL = request.security(syminfo.tickerid, analysisTF, ta.lowest(low, lookback)[1], lookahead = barmerge.lookahead_on)

// --- Detect analysis TF bar changes ---

bool tfBarChange = ta.change(time(analysisTF)) != 0

// --- Track analysis TF bars in arrays ---

var array<float> histH = array.new_float()
var array<float> histL = array.new_float()

if tfBarChange
    array.push(histH, tfHigh)
    array.push(histL, tfLow)
    if array.size(histH) > lookback
        array.shift(histH)
        array.shift(histL)

// --- Hit Rate Tracking (runs every bar) ---

if array.size(historicalLevels) > 0
    float atrCheck = nz(tfAtr, 0.0)
    if atrCheck > 0
        float halfTol = atrCheck * clusterATR * 0.5
        for i = 0 to array.size(historicalLevels) - 1
            if not array.get(levelHit, i)
                float lvl = array.get(historicalLevels, i)
                if low <= lvl + halfTol and high >= lvl - halfTol
                    array.set(levelHit, i, true)
                    totalLevelsHit := totalLevelsHit + 1

// --- Main Logic ---

if barstate.islast
    // Cleanup old drawings
    if array.size(drawnLines) > 0
        for i = 0 to array.size(drawnLines) - 1
            line.delete(array.get(drawnLines, i))
        array.clear(drawnLines)

    if array.size(drawnLabels) > 0
        for i = 0 to array.size(drawnLabels) - 1
            label.delete(array.get(drawnLabels, i))
        array.clear(drawnLabels)

    int histSize = array.size(histH)

    if histSize >= 10 and not na(tfAtr)
        // Step 1: Find all pivots
        array<float> pivotPrices  = array.new_float()
        array<int>   pivotWeights = array.new_int()

        for i = pivotLen to histSize - 1 - pivotLen
            // Recency weight
            int weight = i >= int(histSize * 0.75) ? 3 : i >= int(histSize * 0.25) ? 2 : 1

            // Check pivot high
            bool isPH = true
            float ph = array.get(histH, i)
            for j = 1 to pivotLen
                if array.get(histH, i - j) >= ph or array.get(histH, i + j) >= ph
                    isPH := false
                    break
            if isPH
                array.push(pivotPrices, ph)
                array.push(pivotWeights, weight)

            // Check pivot low
            bool isPL = true
            float pl = array.get(histL, i)
            for j = 1 to pivotLen
                if array.get(histL, i - j) <= pl or array.get(histL, i + j) <= pl
                    isPL := false
                    break
            if isPL
                array.push(pivotPrices, pl)
                array.push(pivotWeights, weight)

        // Step 2: Cluster pivots
        float clusterTol = nz(tfAtr) * clusterATR
        array<float> clusterAvg      = array.new_float()
        array<int>   clusterRawCount = array.new_int()
        array<int>   clusterWeighted = array.new_int()

        if array.size(pivotPrices) > 0
            for i = 0 to array.size(pivotPrices) - 1
                float pp = array.get(pivotPrices, i)
                int   pw = array.get(pivotWeights, i)
                bool  merged = false

                if array.size(clusterAvg) > 0
                    for j = 0 to array.size(clusterAvg) - 1
                        if math.abs(pp - array.get(clusterAvg, j)) <= clusterTol
                            // Merge into existing cluster
                            float oldAvg  = array.get(clusterAvg, j)
                            int   oldCount = array.get(clusterRawCount, j)
                            int   newCount = oldCount + 1
                            array.set(clusterAvg, j, (oldAvg * oldCount + pp) / newCount)
                            array.set(clusterRawCount, j, newCount)
                            array.set(clusterWeighted, j, array.get(clusterWeighted, j) + pw)
                            merged := true
                            break

                if not merged
                    array.push(clusterAvg, pp)
                    array.push(clusterRawCount, 1)
                    array.push(clusterWeighted, pw)

        // Step 3: Select top N levels using while loop with safety counter
        array<float> levels    = array.new_float()
        array<int>   rawCounts = array.new_int()

        // Copy weighted for selection (zero out after picking)
        array<int> selWeighted = array.copy(clusterWeighted)

        int levelsFound = 0
        int attempts    = 0
        while levelsFound < numLevels and attempts < 100
            attempts += 1

            int maxW   = 0
            int maxIdx = -1
            if array.size(selWeighted) > 0
                for k = 0 to array.size(selWeighted) - 1
                    int w = array.get(selWeighted, k)
                    int r = array.get(clusterRawCount, k)
                    if w > maxW and r >= touchPower
                        maxW   := w
                        maxIdx := k

            if maxIdx == -1
                break

            float selectedPrice = array.get(clusterAvg, maxIdx)

            // Check min distance from already selected levels
            bool tooClose = false
            if array.size(levels) > 0
                for k = 0 to array.size(levels) - 1
                    if math.abs(selectedPrice - array.get(levels, k)) < nz(tfAtr) * minDistance
                        tooClose := true
                        break

            // Zero it out regardless so we don't pick it again
            array.set(selWeighted, maxIdx, 0)

            if not tooClose
                array.push(levels, selectedPrice)
                array.push(rawCounts, array.get(clusterRawCount, maxIdx))
                levelsFound += 1

        // Step 4: Draw levels
        if array.size(levels) > 0
            string lStyle = getLineStyle(lineStyle)

            // Find max touch count for strength scaling
            int maxCount = 1
            for i = 0 to array.size(rawCounts) - 1
                int rc = array.get(rawCounts, i)
                if rc > maxCount
                    maxCount := rc

            // Store levels for hit rate tracking
            for i = 0 to array.size(levels) - 1
                float lvlPrice = array.get(levels, i)

                // Add to historical tracking
                array.push(historicalLevels, lvlPrice)
                array.push(levelHit, false)
                array.push(levelBar, bar_index)
                totalLevelsDrawn := totalLevelsDrawn + 1

                // Cap tracking arrays at 50 entries
                if array.size(historicalLevels) > 50
                    array.shift(historicalLevels)
                    array.shift(levelHit)
                    array.shift(levelBar)

            // Draw lines and labels
            for i = 0 to array.size(levels) - 1
                float lvlPrice = array.get(levels, i)
                int   lvlRaw   = array.get(rawCounts, i)

                // Determine base color: support (below price) vs resistance (above price)
                color baseColor = singleColor
                if useAutoColor
                    baseColor := lvlPrice < close ? supportColor : resistanceColor

                // Strength scaling: ratio of this level's touches to the strongest
                float strengthRatio = maxCount > 0 ? float(lvlRaw) / float(maxCount) : 1.0

                // Apply strength-based width and transparency
                int    finalWidth = lineWidth
                color  finalColor = baseColor
                if useStrengthVisual
                    finalWidth := math.max(1, int(math.round(lineWidth * strengthRatio)))
                    int transp = int(50 * (1 - strengthRatio))
                    finalColor := color.new(baseColor, transp)

                line newLine = line.new(bar_index - 100, lvlPrice, bar_index, lvlPrice, extend = extend.both, color = finalColor, width = finalWidth, style = lStyle)
                array.push(drawnLines, newLine)

                if showLabels
                    label newLabel = label.new(bar_index + labelOffset, lvlPrice, str.tostring(lvlPrice, format.mintick) + " (" + str.tostring(lvlRaw) + " touches)", style = label.style_none, textcolor = finalColor, size = getLabelSize(labelSize))
                    array.push(drawnLabels, newLabel)

    // --- Stats Table ---

    if showStats
        var table statsTable = table.new(position.bottom_right, 2, 4, bgcolor = color.new(color.black, 70), border_width = 1, border_color = color.new(color.gray, 50))

        float hitRate = totalLevelsDrawn > 0 ? (float(totalLevelsHit) / float(totalLevelsDrawn)) * 100.0 : 0.0
        color hitRateColor = hitRate > 60 ? color.green : hitRate >= 40 ? color.orange : color.red

        table.cell(statsTable, 0, 0, "Levels Drawn", text_color = color.white, text_size = size.small)
        table.cell(statsTable, 1, 0, str.tostring(totalLevelsDrawn), text_color = color.white, text_size = size.small)
        table.cell(statsTable, 0, 1, "Levels Hit", text_color = color.white, text_size = size.small)
        table.cell(statsTable, 1, 1, str.tostring(totalLevelsHit), text_color = color.white, text_size = size.small)
        table.cell(statsTable, 0, 2, "Hit Rate", text_color = color.white, text_size = size.small)
        table.cell(statsTable, 1, 2, str.tostring(hitRate, "#.#") + "%", text_color = hitRateColor, text_size = size.small)
        table.cell(statsTable, 0, 3, "Clusters Found", text_color = color.white, text_size = size.small)
        table.cell(statsTable, 1, 3, str.tostring(array.size(historicalLevels)), text_color = color.white, text_size = size.small)
