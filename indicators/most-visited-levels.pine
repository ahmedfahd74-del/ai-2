// ============================================================================
// MOST VISITED LEVELS v3 - Consistent S/R Across All Timeframes
// ============================================================================

//@version=6
indicator("Most Visited Levels v3", overlay = true, max_lines_count = 20, max_labels_count = 20)

// --- Inputs ---

lookback    = input.int(200, "Lookback Bars (of analysis TF)", minval = 20, maxval = 2000, group = "Analysis", tooltip = "How many bars of the ANALYSIS timeframe to scan. If MTF=Daily and lookback=200, it scans 200 daily bars regardless of chart TF.")
numLevels   = input.int(5, "Number of Levels", minval = 1, maxval = 10, group = "Analysis")
minDistance  = input.float(1.0, "Min Distance Between Levels (ATR mult)", minval = 0.1, step = 0.1, group = "Analysis")
touchPower  = input.int(3, "Touch Power (min bounces)", minval = 1, maxval = 30, group = "Analysis", tooltip = "Minimum bounces at a level to be shown. Higher = only strongest levels.")
analysisTF  = input.timeframe("D", "Analysis Timeframe", group = "Analysis", tooltip = "Levels are ALWAYS calculated from this timeframe. They stay the same on every chart TF.")

lineColor   = input.color(color.new(color.yellow, 0), "Line Color", group = "Visuals")
lineWidth   = input.int(2, "Line Width", minval = 1, maxval = 5, group = "Visuals")
lineStyle   = input.string("solid", "Line Style", options = ["solid", "dashed", "dotted"], group = "Visuals")
showLabels  = input.bool(true, "Show Price Labels", group = "Visuals")

// --- State ---

var array<line>  drawnLines  = array.new_line()
var array<label> drawnLabels = array.new_label()

// --- Helper ---

getLineStyle(string style) =>
    switch style
        "dashed" => line.style_dashed
        "dotted" => line.style_dotted
        => line.style_solid

// --- Fetch ALL data from the analysis timeframe ---
// These values come from the ANALYSIS TF, not the chart TF

// Use [1] to always get the LAST CONFIRMED bar of the analysis TF (not the forming one)
float tfHigh  = request.security(syminfo.tickerid, analysisTF, high[1], lookahead = barmerge.lookahead_on)
float tfLow   = request.security(syminfo.tickerid, analysisTF, low[1], lookahead = barmerge.lookahead_on)
float tfClose  = request.security(syminfo.tickerid, analysisTF, close[1], lookahead = barmerge.lookahead_on)
float tfOpen   = request.security(syminfo.tickerid, analysisTF, open[1], lookahead = barmerge.lookahead_on)
float tfAtr    = request.security(syminfo.tickerid, analysisTF, ta.atr(14)[1], lookahead = barmerge.lookahead_on)
float tfRangeH = request.security(syminfo.tickerid, analysisTF, ta.highest(high, lookback)[1], lookahead = barmerge.lookahead_on)
float tfRangeL = request.security(syminfo.tickerid, analysisTF, ta.lowest(low, lookback)[1], lookahead = barmerge.lookahead_on)

// --- Detect when analysis TF bar changes (to count only once per TF bar) ---

bool tfBarChange = ta.change(time(analysisTF)) != 0

// --- Track analysis TF bars in arrays for bounce counting ---

var array<float> histH = array.new_float()
var array<float> histL = array.new_float()
var array<float> histC = array.new_float()
var array<float> histO = array.new_float()

if tfBarChange
    array.push(histH, tfHigh)
    array.push(histL, tfLow)
    array.push(histC, tfClose)
    array.push(histO, tfOpen)
    // Cap at lookback size
    if array.size(histH) > lookback
        array.shift(histH)
        array.shift(histL)
        array.shift(histC)
        array.shift(histO)

// --- Main Logic ---

if barstate.islast
    // Cleanup
    if array.size(drawnLines) > 0
        for i = 0 to array.size(drawnLines) - 1
            line.delete(array.get(drawnLines, i))
        array.clear(drawnLines)

    if array.size(drawnLabels) > 0
        for i = 0 to array.size(drawnLabels) - 1
            label.delete(array.get(drawnLabels, i))
        array.clear(drawnLabels)

    int histSize = array.size(histH)

    if histSize >= 10 and not na(tfRangeH) and not na(tfRangeL)
        float rangeHigh = tfRangeH
        float rangeLow  = tfRangeL
        float atrVal    = nz(tfAtr, (rangeHigh - rangeLow) / 50)

        // Auto-calculate bin size from ATR (each bin = ATR * 0.15)
        float binSizeRaw = atrVal * 0.15
        float totalRange = rangeHigh - rangeLow
        int numBins = totalRange > 0 ? math.max(10, math.min(200, int(totalRange / binSizeRaw))) : 50
        float binSize = totalRange / numBins

        if binSize > 0
            // Count bounces from analysis TF history
            array<int> bounceCounts = array.new_int(numBins, 0)

            for i = 0 to histSize - 1
                float barH = array.get(histH, i)
                float barL = array.get(histL, i)
                float barC = array.get(histC, i)
                float barO = array.get(histO, i)

                // Support bounce: low touches bin, close above
                int lowBin = math.max(0, math.min(numBins - 1, int((barL - rangeLow) / binSize)))
                float lowBinTop = rangeLow + (lowBin + 1) * binSize
                if barC > lowBinTop and barL <= lowBinTop
                    array.set(bounceCounts, lowBin, array.get(bounceCounts, lowBin) + 1)

                // Resistance bounce: high touches bin, close below
                int highBin = math.max(0, math.min(numBins - 1, int((barH - rangeLow) / binSize)))
                float highBinBot = rangeLow + highBin * binSize
                if barC < highBinBot and barH >= highBinBot
                    array.set(bounceCounts, highBin, array.get(bounceCounts, highBin) + 1)

            // Find top N levels
            float minDistPrice = atrVal * minDistance
            array<float> levels = array.new_float()
            array<int>   counts = array.new_int()
            string lStyle = getLineStyle(lineStyle)

            for lvl = 0 to numLevels - 1
                int maxCount = 0
                int maxBin   = -1
                for b = 0 to numBins - 1
                    int cnt = array.get(bounceCounts, b)
                    if cnt > maxCount
                        maxCount := cnt
                        maxBin   := b

                if maxBin == -1 or maxCount == 0
                    break

                if maxCount < touchPower
                    break

                float levelPrice = rangeLow + (maxBin + 0.5) * binSize
                array.push(levels, levelPrice)
                array.push(counts, maxCount)

                // Zero nearby bins
                int binsToZero = math.max(1, int(minDistPrice / binSize))
                int zeroStart  = math.max(0, maxBin - binsToZero)
                int zeroEnd    = math.min(numBins - 1, maxBin + binsToZero)
                for b = zeroStart to zeroEnd
                    array.set(bounceCounts, b, 0)

            // Draw
            if array.size(levels) > 0
                for i = 0 to array.size(levels) - 1
                    float lvlPrice = array.get(levels, i)
                    int   lvlCount = array.get(counts, i)

                    line newLine = line.new(bar_index - 100, lvlPrice, bar_index, lvlPrice, extend = extend.both, color = lineColor, width = lineWidth, style = lStyle)
                    array.push(drawnLines, newLine)

                    if showLabels
                        label newLabel = label.new(bar_index + 5, lvlPrice, str.tostring(lvlPrice, format.mintick) + " (" + str.tostring(lvlCount) + "x)", style = label.style_label_left, color = color.new(color.black, 60), textcolor = lineColor, size = size.small)
                        array.push(drawnLabels, newLabel)
