// ============================================================================
// MOST VISITED LEVELS - Automatic Support/Resistance from Price Frequency
// ============================================================================
// Version: 1.0
// ============================================================================

//@version=6
indicator("Most Visited Levels", overlay = true, max_lines_count = 10, max_labels_count = 10)

// --- Inputs ---

lookback    = input.int(500, "Lookback Bars", minval = 50, maxval = 5000, group = "Analysis")
numBins     = input.int(100, "Price Resolution (bins)", minval = 20, maxval = 500, group = "Analysis")
numLevels   = input.int(5, "Number of Levels", minval = 1, maxval = 10, group = "Analysis")
minDistance  = input.float(0.5, "Min Distance Between Levels (ATR mult)", minval = 0.1, group = "Analysis")
minTouches  = input.int(1, "Min Touch Count to Show Level", minval = 1, maxval = 30, group = "Analysis", tooltip = "Only show levels with at least this many touches")

lineColor   = input.color(color.new(color.yellow, 0), "Line Color", group = "Visuals")
lineWidth   = input.int(2, "Line Width", minval = 1, maxval = 5, group = "Visuals")
lineStyle   = input.string("solid", "Line Style", options = ["solid", "dashed", "dotted"], group = "Visuals")
showLabels  = input.bool(true, "Show Price Labels", group = "Visuals")

// --- Constants ---

ATR_LENGTH = 14

// --- State Variables ---

var array<line>  drawnLines  = array.new_line()
var array<label> drawnLabels = array.new_label()

// --- Helper ---

getLineStyle(string style) =>
    switch style
        "dashed" => line.style_dashed
        "dotted" => line.style_dotted
        => line.style_solid

// --- Pre-calculate ta functions at top level (Pine v6 requirement) ---

float _rangeHigh = ta.highest(high, lookback)
float _rangeLow  = ta.lowest(low, lookback)
float _atrValue  = ta.atr(ATR_LENGTH)

// --- Main Logic (only on last bar for performance) ---

if barstate.islast
    // Clean up previous drawings
    if array.size(drawnLines) > 0
        for i = 0 to array.size(drawnLines) - 1
            line.delete(array.get(drawnLines, i))
        array.clear(drawnLines)

    if array.size(drawnLabels) > 0
        for i = 0 to array.size(drawnLabels) - 1
            label.delete(array.get(drawnLabels, i))
        array.clear(drawnLabels)

    // Use pre-calculated values
    int barsAvailable = math.min(lookback - 1, bar_index)
    float rangeHigh   = _rangeHigh
    float rangeLow    = _rangeLow
    float binSize     = (rangeHigh - rangeLow) / numBins

    // Guard against flat market
    if binSize > 0
        // Count touches per bin
        array<int> touchCounts = array.new_int(numBins, 0)

        for i = 0 to barsAvailable
            float barLow  = low[i]
            float barHigh = high[i]
            int binStart  = math.max(0, math.min(numBins - 1, int((barLow - rangeLow) / binSize)))
            int binEnd    = math.max(0, math.min(numBins - 1, int((barHigh - rangeLow) / binSize)))
            for b = binStart to binEnd
                array.set(touchCounts, b, array.get(touchCounts, b) + 1)

        // Find top N levels with minimum distance enforcement
        float minDistPrice   = nz(_atrValue, binSize) * minDistance
        array<float> levels  = array.new_float()
        array<int>   counts  = array.new_int()
        string       lStyle  = getLineStyle(lineStyle)

        for lvl = 0 to numLevels - 1
            int   maxCount = 0
            int   maxBin   = -1
            for b = 0 to numBins - 1
                int cnt = array.get(touchCounts, b)
                if cnt > maxCount
                    maxCount := cnt
                    maxBin   := b

            if maxBin == -1 or maxCount == 0
                break

            if maxCount < minTouches
                break

            float levelPrice = rangeLow + (maxBin + 0.5) * binSize
            array.push(levels, levelPrice)
            array.push(counts, maxCount)

            // Zero out nearby bins to prevent clustering
            int binsToZero = math.max(1, int(minDistPrice / binSize))
            int zeroStart  = math.max(0, maxBin - binsToZero)
            int zeroEnd    = math.min(numBins - 1, maxBin + binsToZero)
            for b = zeroStart to zeroEnd
                array.set(touchCounts, b, 0)

        // Draw lines and labels
        if array.size(levels) > 0
            for i = 0 to array.size(levels) - 1
                float lvlPrice = array.get(levels, i)
                int   lvlCount = array.get(counts, i)

                line newLine = line.new(bar_index - barsAvailable, lvlPrice, bar_index, lvlPrice, extend = extend.both, color = lineColor, width = lineWidth, style = lStyle)
                array.push(drawnLines, newLine)

                if showLabels
                    label newLabel = label.new(bar_index + 5, lvlPrice, str.tostring(lvlPrice, format.mintick) + " (" + str.tostring(lvlCount) + ")", style = label.style_label_left, color = color.new(color.black, 60), textcolor = lineColor, size = size.small)
                    array.push(drawnLabels, newLabel)
