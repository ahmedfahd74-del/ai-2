// --- Persistent Zone Arrays (one per level) ---

var ZoneData[] zonesL1 = array.new<ZoneData>()
var ZoneData[] zonesL2 = array.new<ZoneData>()
var ZoneData[] zonesL3 = array.new<ZoneData>()
var ZoneData[] zonesL4 = array.new<ZoneData>()
var ZoneData[] zonesL5 = array.new<ZoneData>()
var ZoneData[] zonesL6 = array.new<ZoneData>()
var ZoneData[] zonesL7 = array.new<ZoneData>()
var ZoneData[] zonesL8 = array.new<ZoneData>()
var ZoneData[] zonesL9 = array.new<ZoneData>()
var ZoneData[] zonesL10 = array.new<ZoneData>()

// --- Request Security Calls (top-level, one per level) ---
// Each call fetches: [pivotHigh, pivotLow, volume, volumeSma20, atr50]
// Using tuple returns to minimize total security calls (10 total)

[phL1, plL1, volL1, volSmaL1, atrL1] = request.security(syminfo.tickerid, tfL1, [ta.pivothigh(high, swingLenL1, swingLenL1), ta.pivotlow(low, swingLenL1, swingLenL1), volume[swingLenL1], ta.sma(volume, 20)[swingLenL1], ta.atr(50)], lookahead = barmerge.lookahead_off)

[phL2, plL2, volL2, volSmaL2, atrL2] = request.security(syminfo.tickerid, tfL2, [ta.pivothigh(high, swingLenL2, swingLenL2), ta.pivotlow(low, swingLenL2, swingLenL2), volume[swingLenL2], ta.sma(volume, 20)[swingLenL2], ta.atr(50)], lookahead = barmerge.lookahead_off)

[phL3, plL3, volL3, volSmaL3, atrL3] = request.security(syminfo.tickerid, tfL3, [ta.pivothigh(high, swingLenL3, swingLenL3), ta.pivotlow(low, swingLenL3, swingLenL3), volume[swingLenL3], ta.sma(volume, 20)[swingLenL3], ta.atr(50)], lookahead = barmerge.lookahead_off)

[phL4, plL4, volL4, volSmaL4, atrL4] = request.security(syminfo.tickerid, tfL4, [ta.pivothigh(high, swingLenL4, swingLenL4), ta.pivotlow(low, swingLenL4, swingLenL4), volume[swingLenL4], ta.sma(volume, 20)[swingLenL4], ta.atr(50)], lookahead = barmerge.lookahead_off)

[phL5, plL5, volL5, volSmaL5, atrL5] = request.security(syminfo.tickerid, tfL5, [ta.pivothigh(high, swingLenL5, swingLenL5), ta.pivotlow(low, swingLenL5, swingLenL5), volume[swingLenL5], ta.sma(volume, 20)[swingLenL5], ta.atr(50)], lookahead = barmerge.lookahead_off)

[phL6, plL6, volL6, volSmaL6, atrL6] = request.security(syminfo.tickerid, tfL6, [ta.pivothigh(high, swingLenL6, swingLenL6), ta.pivotlow(low, swingLenL6, swingLenL6), volume[swingLenL6], ta.sma(volume, 20)[swingLenL6], ta.atr(50)], lookahead = barmerge.lookahead_off)

[phL7, plL7, volL7, volSmaL7, atrL7] = request.security(syminfo.tickerid, tfL7, [ta.pivothigh(high, swingLenL7, swingLenL7), ta.pivotlow(low, swingLenL7, swingLenL7), volume[swingLenL7], ta.sma(volume, 20)[swingLenL7], ta.atr(50)], lookahead = barmerge.lookahead_off)

[phL8, plL8, volL8, volSmaL8, atrL8] = request.security(syminfo.tickerid, tfL8, [ta.pivothigh(high, swingLenL8, swingLenL8), ta.pivotlow(low, swingLenL8, swingLenL8), volume[swingLenL8], ta.sma(volume, 20)[swingLenL8], ta.atr(50)], lookahead = barmerge.lookahead_off)

[phL9, plL9, volL9, volSmaL9, atrL9] = request.security(syminfo.tickerid, tfL9, [ta.pivothigh(high, swingLenL9, swingLenL9), ta.pivotlow(low, swingLenL9, swingLenL9), volume[swingLenL9], ta.sma(volume, 20)[swingLenL9], ta.atr(50)], lookahead = barmerge.lookahead_off)

[phL10, plL10, volL10, volSmaL10, atrL10] = request.security(syminfo.tickerid, tfL10, [ta.pivothigh(high, swingLenL10, swingLenL10), ta.pivotlow(low, swingLenL10, swingLenL10), volume[swingLenL10], ta.sma(volume, 20)[swingLenL10], ta.atr(50)], lookahead = barmerge.lookahead_off)

// --- Helper: Convert Timeframe to Human-Readable Label ---

tfToLabel(string tf) =>
    string result = switch tf
        'W' => '1W'
        'D' => '1D'
        '240' => '4H'
        '120' => '2H'
        '60' => '1H'
        '30' => '30M'
        '15' => '15M'
        '5' => '5M'
        '3' => '3M'
        '1' => '1M'
        => tf
    result

// --- Process Level Function ---
// Handles zone creation, overlap check, mitigation, decay, and drawing.
// Does NOT call request.security() - receives fetched data as parameters.

processLevel(bool enable, float pivotHigh, float pivotLow, float vol, float volSma, float atrVal, int maxZonesLvl, float minDistAtr, float thicknessAtr, color colorRes, color colorSup, color colorEdge, bool useVolFilter, bool useMitig, bool useDecay, ZoneData[] zones, int extBars, bool showLabels, int decayBarsGlobal, int maxStrikesGlobal, int levelNum, string tf) =>
    bool touchFlag = false
    bool mitigatedFlag = false
    bool newZoneFlag = false
    float atrSafe = nz(atrVal, 0.0)

    // --- Zone Creation: Resistance (from pivot highs) ---
    if enable and not na(pivotHigh) and atrSafe > 0
        bool volValid = useVolFilter ? (vol > volSma) : true
        if volValid
            float zHigh = pivotHigh + atrSafe * thicknessAtr / 2.0
            float zLow = pivotHigh - atrSafe * thicknessAtr / 2.0
            // Overlap prevention
            bool tooClose = false
            if array.size(zones) > 0
                for i = 0 to array.size(zones) - 1
                    ZoneData existing = array.get(zones, i)
                    float existingMid = (existing.priceHigh + existing.priceLow) / 2.0
                    float newMid = (zHigh + zLow) / 2.0
                    if math.abs(existingMid - newMid) < atrSafe * minDistAtr
                        tooClose := true
                        break
            if not tooClose
                // Remove oldest if at capacity
                if array.size(zones) >= maxZonesLvl
                    ZoneData oldest = array.get(zones, 0)
                    int oldestIdx = 0
                    for i = 1 to array.size(zones) - 1
                        ZoneData z = array.get(zones, i)
                        if z.birthBarIndex < oldest.birthBarIndex
                            oldest := z
                            oldestIdx := i
                    ZoneData removed = array.remove(zones, oldestIdx)
                    if not na(removed.boxRef)
                        box.delete(removed.boxRef)
                    if not na(removed.topLine)
                        line.delete(removed.topLine)
                    if not na(removed.botLine)
                        line.delete(removed.botLine)
                    if not na(removed.lblRef)
                        label.delete(removed.lblRef)
                    if not na(removed.centerLine)
                        line.delete(removed.centerLine)
                // Create new resistance zone
                ZoneData newZone = ZoneData.new(zHigh, zLow, -1, bar_index, 0, bar_index, na, na, na, na, na)
                array.push(zones, newZone)
                newZoneFlag := true

    // --- Zone Creation: Support (from pivot lows) ---
    if enable and not na(pivotLow) and atrSafe > 0
        bool volValidS = useVolFilter ? (vol > volSma) : true
        if volValidS
            float zHighS = pivotLow + atrSafe * thicknessAtr / 2.0
            float zLowS = pivotLow - atrSafe * thicknessAtr / 2.0
            // Overlap prevention
            bool tooCloseS = false
            if array.size(zones) > 0
                for i = 0 to array.size(zones) - 1
                    ZoneData existing = array.get(zones, i)
                    float existingMid = (existing.priceHigh + existing.priceLow) / 2.0
                    float newMid = (zHighS + zLowS) / 2.0
                    if math.abs(existingMid - newMid) < atrSafe * minDistAtr
                        tooCloseS := true
                        break
            if not tooCloseS
                // Remove oldest if at capacity
                if array.size(zones) >= maxZonesLvl
                    ZoneData oldest = array.get(zones, 0)
                    int oldestIdx = 0
                    for i = 1 to array.size(zones) - 1
                        ZoneData z = array.get(zones, i)
                        if z.birthBarIndex < oldest.birthBarIndex
                            oldest := z
                            oldestIdx := i
                    ZoneData removed = array.remove(zones, oldestIdx)
                    if not na(removed.boxRef)
                        box.delete(removed.boxRef)
                    if not na(removed.topLine)
                        line.delete(removed.topLine)
                    if not na(removed.botLine)
                        line.delete(removed.botLine)
                    if not na(removed.lblRef)
                        label.delete(removed.lblRef)
                    if not na(removed.centerLine)
                        line.delete(removed.centerLine)
                // Create new support zone
                ZoneData newZone = ZoneData.new(zHighS, zLowS, 1, bar_index, 0, bar_index, na, na, na, na, na)
                array.push(zones, newZone)
                newZoneFlag := true

    // --- Mitigation: Check for zone breaches ---
    if enable and useMitig and barstate.isconfirmed and array.size(zones) > 0
        int idx = array.size(zones) - 1
        while idx >= 0
            ZoneData zone = array.get(zones, idx)
            bool breached = false
            if zone.direction == -1
                // Resistance: breached if close > priceHigh
                if close > zone.priceHigh
                    breached := true
            else
                // Support: breached if close < priceLow
                if close < zone.priceLow
                    breached := true
            if breached
                zone.strikes += 1
                if zone.strikes >= maxStrikesGlobal
                    // Delete drawing objects
                    if not na(zone.boxRef)
                        box.delete(zone.boxRef)
                    if not na(zone.topLine)
                        line.delete(zone.topLine)
                    if not na(zone.botLine)
                        line.delete(zone.botLine)
                    if not na(zone.lblRef)
                        label.delete(zone.lblRef)
                    if not na(zone.centerLine)
                        line.delete(zone.centerLine)
                    array.remove(zones, idx)
                    mitigatedFlag := true
            idx -= 1

    // --- Zone Touch Detection ---
    if enable and barstate.isconfirmed and array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            ZoneData zone = array.get(zones, i)
            if high >= zone.priceLow and low <= zone.priceHigh
                touchFlag := true
                break

    // --- Drawing: Update visuals for all zones ---
    if enable and array.size(zones) > 0
        string tfLabel = tfToLabel(tf)
        for i = 0 to array.size(zones) - 1
            ZoneData zone = array.get(zones, i)
            // Calculate alpha decay
            int alpha = 0
            if useDecay
                alpha := math.min(90, int((bar_index - zone.birthBarIndex) * 80.0 / math.max(decayBarsGlobal, 1)))
            // Determine fill color with decay
            color fillColor = zone.direction == -1 ? color.new(colorRes, alpha) : color.new(colorSup, alpha)
            // Delete old drawing objects
            if not na(zone.boxRef)
                box.delete(zone.boxRef)
            if not na(zone.topLine)
                line.delete(zone.topLine)
            if not na(zone.botLine)
                line.delete(zone.botLine)
            if not na(zone.lblRef)
                label.delete(zone.lblRef)
            // Draw box (zone fill)
            zone.boxRef := box.new(zone.birthBarIndex, zone.priceHigh, bar_index + extBars, zone.priceLow, border_color = color.new(colorEdge, 0), border_width = 1, bgcolor = fillColor, xloc = xloc.bar_index)
            // Draw top and bottom boundary lines (extend.both)
            zone.topLine := line.new(bar_index - 1, zone.priceHigh, bar_index, zone.priceHigh, xloc = xloc.bar_index, extend = extend.both, color = colorEdge, style = line.style_solid, width = 1)
            zone.botLine := line.new(bar_index - 1, zone.priceLow, bar_index, zone.priceLow, xloc = xloc.bar_index, extend = extend.both, color = colorEdge, style = line.style_solid, width = 1)
            // Draw text label
            if showLabels
                string labelText = (zone.direction == -1 ? "R" : "S") + " [" + tfLabel + "]"
                zone.lblRef := label.new(bar_index + extBars, (zone.priceHigh + zone.priceLow) / 2.0, labelText, xloc = xloc.bar_index, style = label.style_none, textcolor = colorEdge, size = size.small)


    [touchFlag, mitigatedFlag, newZoneFlag]

// --- Process All 10 Levels ---

[touchL1, mitigL1, newL1] = processLevel(enableL1, phL1, plL1, volL1, volSmaL1, atrL1, maxZonesL1, minDistAtrL1, thicknessAtrL1, colorResFillL1, colorSupFillL1, colorEdgeL1, useVolFilterL1, useMitigationL1, useAlphaDecayL1, zonesL1, extendBarsRight, showTextLabels, decayBars, maxStrikes, 1, tfL1)

[touchL2, mitigL2, newL2] = processLevel(enableL2, phL2, plL2, volL2, volSmaL2, atrL2, maxZonesL2, minDistAtrL2, thicknessAtrL2, colorResFillL2, colorSupFillL2, colorEdgeL2, useVolFilterL2, useMitigationL2, useAlphaDecayL2, zonesL2, extendBarsRight, showTextLabels, decayBars, maxStrikes, 2, tfL2)

[touchL3, mitigL3, newL3] = processLevel(enableL3, phL3, plL3, volL3, volSmaL3, atrL3, maxZonesL3, minDistAtrL3, thicknessAtrL3, colorResFillL3, colorSupFillL3, colorEdgeL3, useVolFilterL3, useMitigationL3, useAlphaDecayL3, zonesL3, extendBarsRight, showTextLabels, decayBars, maxStrikes, 3, tfL3)

[touchL4, mitigL4, newL4] = processLevel(enableL4, phL4, plL4, volL4, volSmaL4, atrL4, maxZonesL4, minDistAtrL4, thicknessAtrL4, colorResFillL4, colorSupFillL4, colorEdgeL4, useVolFilterL4, useMitigationL4, useAlphaDecayL4, zonesL4, extendBarsRight, showTextLabels, decayBars, maxStrikes, 4, tfL4)

[touchL5, mitigL5, newL5] = processLevel(enableL5, phL5, plL5, volL5, volSmaL5, atrL5, maxZonesL5, minDistAtrL5, thicknessAtrL5, colorResFillL5, colorSupFillL5, colorEdgeL5, useVolFilterL5, useMitigationL5, useAlphaDecayL5, zonesL5, extendBarsRight, showTextLabels, decayBars, maxStrikes, 5, tfL5)

[touchL6, mitigL6, newL6] = processLevel(enableL6, phL6, plL6, volL6, volSmaL6, atrL6, maxZonesL6, minDistAtrL6, thicknessAtrL6, colorResFillL6, colorSupFillL6, colorEdgeL6, useVolFilterL6, useMitigationL6, useAlphaDecayL6, zonesL6, extendBarsRight, showTextLabels, decayBars, maxStrikes, 6, tfL6)

[touchL7, mitigL7, newL7] = processLevel(enableL7, phL7, plL7, volL7, volSmaL7, atrL7, maxZonesL7, minDistAtrL7, thicknessAtrL7, colorResFillL7, colorSupFillL7, colorEdgeL7, useVolFilterL7, useMitigationL7, useAlphaDecayL7, zonesL7, extendBarsRight, showTextLabels, decayBars, maxStrikes, 7, tfL7)

[touchL8, mitigL8, newL8] = processLevel(enableL8, phL8, plL8, volL8, volSmaL8, atrL8, maxZonesL8, minDistAtrL8, thicknessAtrL8, colorResFillL8, colorSupFillL8, colorEdgeL8, useVolFilterL8, useMitigationL8, useAlphaDecayL8, zonesL8, extendBarsRight, showTextLabels, decayBars, maxStrikes, 8, tfL8)

[touchL9, mitigL9, newL9] = processLevel(enableL9, phL9, plL9, volL9, volSmaL9, atrL9, maxZonesL9, minDistAtrL9, thicknessAtrL9, colorResFillL9, colorSupFillL9, colorEdgeL9, useVolFilterL9, useMitigationL9, useAlphaDecayL9, zonesL9, extendBarsRight, showTextLabels, decayBars, maxStrikes, 9, tfL9)

[touchL10, mitigL10, newL10] = processLevel(enableL10, phL10, plL10, volL10, volSmaL10, atrL10, maxZonesL10, minDistAtrL10, thicknessAtrL10, colorResFillL10, colorSupFillL10, colorEdgeL10, useVolFilterL10, useMitigationL10, useAlphaDecayL10, zonesL10, extendBarsRight, showTextLabels, decayBars, maxStrikes, 10, tfL10)

// --- POI Centerlines (drawn separately to avoid UDT field limits) ---

drawCenterlines(bool enable, bool showCenterlines, ZoneData[] zones, color edgeColor) =>
    if enable and showCenterlines and array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            ZoneData zone = array.get(zones, i)
            float mid = (zone.priceHigh + zone.priceLow) / 2.0
            if not na(zone.centerLine)
                line.delete(zone.centerLine)
            zone.centerLine := line.new(bar_index - 1, mid, bar_index, mid, xloc = xloc.bar_index, extend = extend.both, color = color.new(edgeColor, 50), style = line.style_dotted, width = 1)

drawCenterlines(enableL1, showPOICenterlines, zonesL1, colorEdgeL1)
drawCenterlines(enableL2, showPOICenterlines, zonesL2, colorEdgeL2)
drawCenterlines(enableL3, showPOICenterlines, zonesL3, colorEdgeL3)
drawCenterlines(enableL4, showPOICenterlines, zonesL4, colorEdgeL4)
drawCenterlines(enableL5, showPOICenterlines, zonesL5, colorEdgeL5)
drawCenterlines(enableL6, showPOICenterlines, zonesL6, colorEdgeL6)
drawCenterlines(enableL7, showPOICenterlines, zonesL7, colorEdgeL7)
drawCenterlines(enableL8, showPOICenterlines, zonesL8, colorEdgeL8)
drawCenterlines(enableL9, showPOICenterlines, zonesL9, colorEdgeL9)
drawCenterlines(enableL10, showPOICenterlines, zonesL10, colorEdgeL10)

// --- Aggregate Alert Flags ---

bool anyTouch = touchL1 or touchL2 or touchL3 or touchL4 or touchL5 or touchL6 or touchL7 or touchL8 or touchL9 or touchL10
bool anyMitigated = mitigL1 or mitigL2 or mitigL3 or mitigL4 or mitigL5 or mitigL6 or mitigL7 or mitigL8 or mitigL9 or mitigL10
bool anyNewZone = newL1 or newL2 or newL3 or newL4 or newL5 or newL6 or newL7 or newL8 or newL9 or newL10

// --- Dynamic Alerts ---

if anyTouch
    alert("Zone Touch on " + syminfo.ticker + " - Price interacting with S/R zone", alert.freq_once_per_bar)

if anyMitigated
    alert("Zone Mitigated on " + syminfo.ticker + " - S/R zone removed after max strikes", alert.freq_once_per_bar)

if anyNewZone
    alert("New Zone Created on " + syminfo.ticker + " - New S/R zone detected", alert.freq_once_per_bar)

// --- Alert Conditions ---

alertcondition(anyTouch, title = "Zone Touch", message = "{{ticker}}: Price touched an S/R zone boundary")
alertcondition(anyMitigated, title = "Zone Mitigated", message = "{{ticker}}: An S/R zone was mitigated and removed")
alertcondition(anyNewZone, title = "New Zone Created", message = "{{ticker}}: A new S/R zone was created")
