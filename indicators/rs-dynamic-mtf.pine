// ============================================================================
// R&S Dynamic MTF [10-Layer] - Multi-Timeframe Support & Resistance System
// ============================================================================
// A comprehensive Pine Script v6 indicator implementing 10 independent S/R
// zone layers with per-layer multi-timeframe swing detection, volume
// validation, ATR-based zone thickness, overlap prevention, 3-strike
// mitigation, and alpha decay.
//
// Features:
//   - 10 independent layers, each with its own timeframe and settings
//   - Swing-based zone detection with volume confirmation
//   - ATR-adaptive zone thickness
//   - Overlap prevention (minimum ATR distance between same-level zones)
//   - Strike-based mitigation (zones removed after N breaches)
//   - Alpha decay (zones fade over time)
//   - Extend-both boundary lines for full visibility
//   - Per-level color coding with spectral progression
//   - POI centerlines at zone midpoints
//   - Alert conditions for zone touch, mitigation, and creation
//
// Version: 1.0
// ============================================================================

//@version=6
indicator('R&S Dynamic MTF [10-Layer]', overlay = true, max_boxes_count = 500, max_labels_count = 500, max_lines_count = 500)

// --- User Defined Types ---

type ZoneData
    float priceHigh
    float priceLow
    int direction       // 1 = support, -1 = resistance
    int birthBar
    int strikes
    int birthBarIndex
    box boxRef
    line topLine
    line botLine
    label lblRef
    line centerLine

// --- Global Settings ---

string GRP_GLOBAL = "0. Global Settings"
int extendBarsRight = input.int(50, "Extend Bars Right", minval = 1, maxval = 500, group = GRP_GLOBAL, tooltip = "How far to extend zone boxes to the right")
bool showTextLabels = input.bool(true, "Show Text Labels", group = GRP_GLOBAL, tooltip = "Show R/S labels with timeframe info")
bool showPOICenterlines = input.bool(true, "Show POI Centerlines", group = GRP_GLOBAL, tooltip = "Show dotted centerline at zone midpoint")
int decayBars = input.int(100, "Decay Bars", minval = 10, maxval = 1000, group = GRP_GLOBAL, tooltip = "Number of bars for full alpha decay")
int maxStrikes = input.int(3, "Max Strikes", minval = 1, maxval = 10, group = GRP_GLOBAL, tooltip = "Strikes before zone is mitigated and removed")

