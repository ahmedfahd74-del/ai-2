// ============================================================================
// SWING TRADING FRAMEWORK
// ============================================================================
// A comprehensive Pine Script v5 swing trading indicator that combines:
//   - Weekly bias detection via pivot structure
//   - Daily alignment confirmation
//   - 4H structure analysis
//   - Multi-level Support/Resistance from chart-timeframe pivots
//   - EMA trend filter
//   - Liquidity sweep detection with volume confirmation
//   - Full entry/SL/TP calculation with configurable R:R
//   - Dynamic TP targeting at HTF zones
//   - Round psychological level TP enhancement
//   - Session/Kill Zone filtering (London, New York)
//   - Signal expiry management with weekly close hold logic
//   - Partial position / trailing stop concept (TP1 hit -> move SL to BE)
//   - Retracement and Continuation trade modes
//   - Trend leg expectation analysis
//   - Weekly structure labels on chart
//
// Features:
//   - Non-repainting signals using barstate.isconfirmed
//   - Anti-repaint MTF data via barmerge.lookahead_off
//   - Dashboard with complete trade state (25 rows)
//   - Visual trade levels (entry, SL, TP1, TP2)
//   - Multi-level S/R plotting (up to 3 each, different line styles)
//   - Weekly structure labels (HH/HL/LH/LL)
//   - Alert conditions and dynamic JSON alerts
//
// Version: 3.0
// ============================================================================

//@version=5
indicator("Swing Trading Framework", overlay=true, max_lines_count=500, max_labels_count=500)

// --- Inputs ---

// Core Settings
emaLength       = input.int(50, "EMA Length", minval=1)
weeklyEmaLength = input.int(21, "Weekly EMA Length", minval=1)
dailyEmaLength  = input.int(21, "Daily EMA Length", minval=1)
pivotLeftBars   = input.int(5, "Pivot Left Bars", minval=1, maxval=20)
pivotRightBars  = input.int(5, "Pivot Right Bars", minval=1, maxval=20)
atrLength       = input.int(14, "ATR Length", minval=1)
atrMultiplier   = input.float(1.5, "ATR Multiplier for SL", minval=0.1, step=0.1)
rr1             = input.float(2.0, "Risk:Reward 1", minval=0.5, step=0.5)
rr2             = input.float(3.0, "Risk:Reward 2", minval=1.0, step=0.5)
useLiquiditySweep = input.bool(true, "Use Liquidity Sweep Filter")
htfPivotLength  = input.int(3, "HTF Pivot Length", minval=1, maxval=10)

// Trade Mode
tradeMode = input.string("Both", "Trade Mode", options=["Continuation", "Retracement", "Both"], group="Trade Mode", tooltip="Continuation: trade with weekly trend. Retracement: trade expected pullbacks against weekly trend. Both: allow either.")

// Kill Zones
useKillZones     = input.bool(true, "Use Kill Zone Filter", group="Kill Zones")
killZoneTimezone = input.string("America/New_York", "Kill Zone Timezone", options=["America/New_York", "Europe/London", "UTC"], group="Kill Zones")
londonSession    = input.session("0200-0500", "London Session", group="Kill Zones")
nySession        = input.session("0830-1100", "New York Session", group="Kill Zones")

// Volume
useVolumeSweepFilter = input.bool(true, "Volume Confirmation for Sweeps", group="Volume", tooltip="Require volume spike on sweep bar")
volumeSweepMult      = input.float(1.5, "Volume Sweep Multiplier", minval=0.5, step=0.1, group="Volume", tooltip="Volume on sweep bar must exceed this multiple of average volume")
volumeSmaLength      = input.int(20, "Volume SMA Length", minval=1, group="Volume")

// Signal Management
signalExpiryBars    = input.int(10, "Signal Expiry (bars)", minval=1, group="Signal Management", tooltip="Signal expires after this many bars if not acted on")
useDynamicTP        = input.bool(true, "Use Dynamic TP (Weekly Zone)", group="Signal Management", tooltip="TP2 targets nearest weekly resistance/support zone when available")
useWeeklyHoldLogic  = input.bool(true, "Weekly Close Hold Logic", group="Signal Management", tooltip="Extend signal expiry when weekly candle confirms direction")
useRoundNumberTP    = input.bool(false, "Use Round Number TP", group="Signal Management", tooltip="Adjust TP2 to nearest psychological round number if between TP1 and TP2")

// Visuals
showStructureLabels = input.bool(true, "Show Weekly Structure Labels", group="Visuals", tooltip="Draw HH/HL/LH/LL labels on chart from weekly pivots")

// --- Constants ---

string BULLISH = "Bullish"
string BEARISH = "Bearish"
string NEUTRAL = "Neutral"
string LONG_READY  = "LONG READY"
string SHORT_READY = "SHORT READY"
string NO_SETUP    = "NO SETUP"

// --- EMA Calculation (Chart Timeframe) ---

emaValue = ta.ema(close, emaLength)
isAboveEma = close > emaValue
isBelowEma = close < emaValue

// --- ATR Calculation ---

atrValue = ta.atr(atrLength)

// --- Kill Zone Detection ---

bool inLondonKZ = not na(time(timeframe.period, londonSession, killZoneTimezone))
bool inNyKZ     = not na(time(timeframe.period, nySession, killZoneTimezone))
bool inAnyKZ    = inLondonKZ or inNyKZ

// Kill zone status string for dashboard
string killZoneStatus = useKillZones ? (inLondonKZ ? "London" : inNyKZ ? "NY" : "Off-Hours") : "Disabled"

// --- Volume SMA for Sweep Confirmation ---

float volumeSma = ta.sma(volume, volumeSmaLength)

// --- Section 1: Weekly Bias ---

// Fetch weekly pivot data
weeklyHigh  = request.security(syminfo.tickerid, "W", high, barmerge.gaps_off, barmerge.lookahead_off)
weeklyLow   = request.security(syminfo.tickerid, "W", low, barmerge.gaps_off, barmerge.lookahead_off)
weeklyClose = request.security(syminfo.tickerid, "W", close, barmerge.gaps_off, barmerge.lookahead_off)

// Weekly EMA for fallback
weeklyEma = request.security(syminfo.tickerid, "W", ta.ema(close, weeklyEmaLength), barmerge.gaps_off, barmerge.lookahead_off)

// Weekly pivot detection
weeklyPivotHigh = request.security(syminfo.tickerid, "W", ta.pivothigh(high, htfPivotLength, htfPivotLength), barmerge.gaps_off, barmerge.lookahead_off)
weeklyPivotLow  = request.security(syminfo.tickerid, "W", ta.pivotlow(low, htfPivotLength, htfPivotLength), barmerge.gaps_off, barmerge.lookahead_off)

// Track last two weekly pivot highs and lows using ta.valuewhen
lastWeeklyPH  = ta.valuewhen(not na(weeklyPivotHigh), weeklyPivotHigh, 0)
prevWeeklyPH  = ta.valuewhen(not na(weeklyPivotHigh), weeklyPivotHigh, 1)
lastWeeklyPL  = ta.valuewhen(not na(weeklyPivotLow), weeklyPivotLow, 0)
prevWeeklyPL  = ta.valuewhen(not na(weeklyPivotLow), weeklyPivotLow, 1)

// Determine weekly bias
var string weeklyBias = NEUTRAL

if not na(lastWeeklyPH) and not na(prevWeeklyPH) and not na(lastWeeklyPL) and not na(prevWeeklyPL)
    // HH + HL = Bullish
    if lastWeeklyPH > prevWeeklyPH and lastWeeklyPL > prevWeeklyPL
        weeklyBias := BULLISH
    // LH + LL = Bearish
    else if lastWeeklyPH < prevWeeklyPH and lastWeeklyPL < prevWeeklyPL
        weeklyBias := BEARISH
    else
        weeklyBias := NEUTRAL
else
    // Fallback: weekly close vs weekly EMA
    if not na(weeklyClose) and not na(weeklyEma)
        if weeklyClose > weeklyEma
            weeklyBias := BULLISH
        else if weeklyClose < weeklyEma
            weeklyBias := BEARISH
        else
            weeklyBias := NEUTRAL
    else
        weeklyBias := NEUTRAL

// --- Section 1b: Weekly Candle Close Detection ---

// Track the last closed weekly candle direction (using [1] with lookahead_on for confirmed previous close)
bool weeklyClosedBullish = request.security(syminfo.tickerid, "W", close[1] > open[1], barmerge.gaps_off, barmerge.lookahead_on)
bool weeklyClosedBearish = request.security(syminfo.tickerid, "W", close[1] < open[1], barmerge.gaps_off, barmerge.lookahead_on)

// --- Section 1c: Dynamic TP - Weekly Resistance/Support Zones ---

// Fetch weekly resistance (last weekly pivot high) and weekly support (last weekly pivot low)
float weeklyResistanceZone = ta.valuewhen(not na(weeklyPivotHigh), weeklyPivotHigh, 0)
float weeklySupportZone    = ta.valuewhen(not na(weeklyPivotLow), weeklyPivotLow, 0)

// --- Section 2: Daily Alignment ---

// Fetch daily data
dailyClose = request.security(syminfo.tickerid, "D", close, barmerge.gaps_off, barmerge.lookahead_off)
dailyEma   = request.security(syminfo.tickerid, "D", ta.ema(close, dailyEmaLength), barmerge.gaps_off, barmerge.lookahead_off)

// Daily pivot detection
dailyPivotHigh = request.security(syminfo.tickerid, "D", ta.pivothigh(high, htfPivotLength, htfPivotLength), barmerge.gaps_off, barmerge.lookahead_off)
dailyPivotLow  = request.security(syminfo.tickerid, "D", ta.pivotlow(low, htfPivotLength, htfPivotLength), barmerge.gaps_off, barmerge.lookahead_off)

// Track last two daily pivot highs and lows
lastDailyPH = ta.valuewhen(not na(dailyPivotHigh), dailyPivotHigh, 0)
prevDailyPH = ta.valuewhen(not na(dailyPivotHigh), dailyPivotHigh, 1)
lastDailyPL = ta.valuewhen(not na(dailyPivotLow), dailyPivotLow, 0)
prevDailyPL = ta.valuewhen(not na(dailyPivotLow), dailyPivotLow, 1)

// Determine daily alignment
var string dailyAlignment = NEUTRAL

if not na(dailyClose) and not na(dailyEma)
    // Bullish alignment: close > EMA AND (HH pattern OR close > last pivot high)
    if dailyClose > dailyEma and (( not na(lastDailyPH) and not na(prevDailyPH) and lastDailyPH > prevDailyPH) or (not na(lastDailyPH) and dailyClose > lastDailyPH))
        dailyAlignment := BULLISH
    // Bearish alignment: close < EMA AND (LL pattern OR close < last pivot low)
    else if dailyClose < dailyEma and ((not na(lastDailyPL) and not na(prevDailyPL) and lastDailyPL < prevDailyPL) or (not na(lastDailyPL) and dailyClose < lastDailyPL))
        dailyAlignment := BEARISH
    else
        dailyAlignment := NEUTRAL
else
    dailyAlignment := NEUTRAL

// --- Section 2b: 4H Structure Detection ---

h4PivotHigh = request.security(syminfo.tickerid, "240", ta.pivothigh(high, htfPivotLength, htfPivotLength), barmerge.gaps_off, barmerge.lookahead_off)
h4PivotLow  = request.security(syminfo.tickerid, "240", ta.pivotlow(low, htfPivotLength, htfPivotLength), barmerge.gaps_off, barmerge.lookahead_off)
lastH4PH = ta.valuewhen(not na(h4PivotHigh), h4PivotHigh, 0)
prevH4PH = ta.valuewhen(not na(h4PivotHigh), h4PivotHigh, 1)
lastH4PL = ta.valuewhen(not na(h4PivotLow), h4PivotLow, 0)
prevH4PL = ta.valuewhen(not na(h4PivotLow), h4PivotLow, 1)

// --- Section 2c: Structure String Calculation ---

// Helper: build structure string from pivot comparisons
getStructureStr(float _lastPH, float _prevPH, float _lastPL, float _prevPL) =>
    string phPart = na
    string plPart = na
    if not na(_lastPH) and not na(_prevPH)
        phPart := _lastPH > _prevPH ? "HH" : "LH"
    if not na(_lastPL) and not na(_prevPL)
        plPart := _lastPL > _prevPL ? "HL" : "LL"
    string result = na
    if not na(phPart) and not na(plPart)
        result := phPart + " + " + plPart
    else if not na(phPart)
        result := phPart
    else if not na(plPart)
        result := plPart
    else
        result := "---"
    result

string weeklyStructure = getStructureStr(lastWeeklyPH, prevWeeklyPH, lastWeeklyPL, prevWeeklyPL)
string dailyStructure  = getStructureStr(lastDailyPH, prevDailyPH, lastDailyPL, prevDailyPL)
string h4Structure     = getStructureStr(lastH4PH, prevH4PH, lastH4PL, prevH4PL)

// Structure color helper
getStructureColor(string s) =>
    color result = color.yellow
    if s == "HH + HL"
        result := color.green
    else if s == "LH + LL"
        result := color.red
    else
        result := color.yellow
    result

// --- Section 2d: Trend Leg Expectation ---

string trendExpectation = "---"
color expectationColor = color.gray

if not na(lastWeeklyPH) and not na(lastWeeklyPL)
    float weeklyRange = math.abs(lastWeeklyPH - lastWeeklyPL)
    float threshold = weeklyRange * 0.3
    if weeklyBias == BEARISH
        // Bearish trend: LH + LL
        if close <= lastWeeklyPL + threshold
            trendExpectation := "Expecting: Retracement UP"
            expectationColor := color.lime
        else if close >= lastWeeklyPH - threshold
            trendExpectation := "Expecting: Continuation DOWN"
            expectationColor := color.red
        else
            trendExpectation := "Bearish Mid-Range"
            expectationColor := color.orange
    else if weeklyBias == BULLISH
        // Bullish trend: HH + HL
        if close >= lastWeeklyPH - threshold
            trendExpectation := "Expecting: Retracement DOWN"
            expectationColor := color.orange
        else if close <= lastWeeklyPL + threshold
            trendExpectation := "Expecting: Continuation UP"
            expectationColor := color.green
        else
            trendExpectation := "Bullish Mid-Range"
            expectationColor := color.lime
    else
        trendExpectation := "Neutral / Ranging"
        expectationColor := color.gray

// --- Section 3: Multi-Level Support / Resistance ---

// Detect pivots on chart timeframe
pivotHigh = ta.pivothigh(high, pivotLeftBars, pivotRightBars)
pivotLow  = ta.pivotlow(low, pivotLeftBars, pivotRightBars)

// Store last 3 support and resistance levels
var float[] supportLevels    = array.new_float(0)
var float[] resistanceLevels = array.new_float(0)

if not na(pivotHigh)
    array.push(resistanceLevels, pivotHigh)
    if array.size(resistanceLevels) > 3
        array.shift(resistanceLevels)

if not na(pivotLow)
    array.push(supportLevels, pivotLow)
    if array.size(supportLevels) > 3
        array.shift(supportLevels)

// Find nearest support below price and nearest resistance above price
float nearestSupport    = na
float nearestResistance = na

if array.size(supportLevels) > 0
    for i = 0 to array.size(supportLevels) - 1
        float lvl = array.get(supportLevels, i)
        if lvl < close
            if na(nearestSupport) or lvl > nearestSupport
                nearestSupport := lvl

if array.size(resistanceLevels) > 0
    for i = 0 to array.size(resistanceLevels) - 1
        float lvl = array.get(resistanceLevels, i)
        if lvl > close
            if na(nearestResistance) or lvl < nearestResistance
                nearestResistance := lvl

// Fallback: if no level found on correct side, use most recent
if na(nearestSupport) and array.size(supportLevels) > 0
    nearestSupport := array.get(supportLevels, array.size(supportLevels) - 1)

if na(nearestResistance) and array.size(resistanceLevels) > 0
    nearestResistance := array.get(resistanceLevels, array.size(resistanceLevels) - 1)

// Legacy variable names for compatibility with trade logic
float supportLevel    = nearestSupport
float resistanceLevel = nearestResistance

// --- Section 4: EMA Filter ---

string emaStatus = isAboveEma ? BULLISH : isBelowEma ? BEARISH : NEUTRAL

// --- Section 5: Liquidity Sweep Detection (with Volume Confirmation) ---

var string sweepStatus = "None"
var bool sweepVolumeConfirmed = false

if barstate.isconfirmed
    // Bullish sweep: wick below support, close back above
    if useLiquiditySweep and not na(supportLevel) and low < supportLevel and close > supportLevel
        bool volOk = useVolumeSweepFilter ? (volume > volumeSma * volumeSweepMult) : true
        sweepStatus := BULLISH
        sweepVolumeConfirmed := volOk
    // Bearish sweep: wick above resistance, close back below
    else if useLiquiditySweep and not na(resistanceLevel) and high > resistanceLevel and close < resistanceLevel
        bool volOk = useVolumeSweepFilter ? (volume > volumeSma * volumeSweepMult) : true
        sweepStatus := BEARISH
        sweepVolumeConfirmed := volOk
    else
        sweepStatus := "None"
        sweepVolumeConfirmed := false

// --- Section 5b: Round Psychological Level Calculation ---

getRoundLevel(float price, bool above) =>
    float increment = 0.1
    if price > 10000
        increment := 1000.0
    else if price > 1000
        increment := 100.0
    else if price > 100
        increment := 10.0
    else if price > 10
        increment := 1.0
    else
        increment := 0.1
    float result = na
    if above
        result := math.ceil(price / increment) * increment
    else
        result := math.floor(price / increment) * increment
    result

float roundLevelAbove = getRoundLevel(close, true)
float roundLevelBelow = getRoundLevel(close, false)

// --- Section 6: Entry / SL / TP Logic ---

var string tradeStatus = NO_SETUP
var float entryPrice   = na
var float slPrice      = na
var float tp1Price     = na
var float tp2Price     = na
var string tp2Source   = "Fixed RR"

// Signal expiry tracking
var int signalBar = na

// TP1 hit tracking (partial position / trailing concept)
var bool tp1Hit = false

// --- Section 6b: Continuation Conditions ---

// Condition checks for long setup (continuation)
bool contLongWeeklyOk  = weeklyBias == BULLISH or (weeklyBias == NEUTRAL and dailyAlignment == BULLISH)
bool contLongDailyOk   = dailyAlignment == BULLISH
bool contLongEmaOk     = isAboveEma
bool contLongSupportOk = not na(supportLevel) and (close > supportLevel or (low < supportLevel and close > supportLevel))
bool contLongSweepOk   = useLiquiditySweep ? (sweepStatus == BULLISH and (useVolumeSweepFilter ? sweepVolumeConfirmed : true)) : true

// Condition checks for short setup (continuation)
bool contShortWeeklyOk  = weeklyBias == BEARISH or (weeklyBias == NEUTRAL and dailyAlignment == BEARISH)
bool contShortDailyOk   = dailyAlignment == BEARISH
bool contShortEmaOk     = isBelowEma
bool contShortResistOk  = not na(resistanceLevel) and (close < resistanceLevel or (high > resistanceLevel and close < resistanceLevel))
bool contShortSweepOk   = useLiquiditySweep ? (sweepStatus == BEARISH and (useVolumeSweepFilter ? sweepVolumeConfirmed : true)) : true

// --- Section 6c: Retracement Conditions ---

// Retracement LONG: weekly bearish (expecting pullback UP), daily bullish (retracement starting)
bool retLongWeeklyOk  = weeklyBias == BEARISH
bool retLongDailyOk   = dailyAlignment == BULLISH
bool retLongEmaOk     = isAboveEma
bool retLongSupportOk = not na(supportLevel) and (close > supportLevel or (low < supportLevel and close > supportLevel))
bool retLongSweepOk   = useLiquiditySweep ? (sweepStatus == BULLISH and (useVolumeSweepFilter ? sweepVolumeConfirmed : true)) : true

// Retracement SHORT: weekly bullish (expecting pullback DOWN), daily bearish (retracement starting)
bool retShortWeeklyOk  = weeklyBias == BULLISH
bool retShortDailyOk   = dailyAlignment == BEARISH
bool retShortEmaOk     = isBelowEma
bool retShortResistOk  = not na(resistanceLevel) and (close < resistanceLevel or (high > resistanceLevel and close < resistanceLevel))
bool retShortSweepOk   = useLiquiditySweep ? (sweepStatus == BEARISH and (useVolumeSweepFilter ? sweepVolumeConfirmed : true)) : true

// --- Section 6d: Combined Trade Conditions Based on Mode ---

bool longContinuationOk  = contLongWeeklyOk and contLongDailyOk and contLongEmaOk and contLongSupportOk and contLongSweepOk
bool shortContinuationOk = contShortWeeklyOk and contShortDailyOk and contShortEmaOk and contShortResistOk and contShortSweepOk
bool longRetracementOk   = retLongWeeklyOk and retLongDailyOk and retLongEmaOk and retLongSupportOk and retLongSweepOk
bool shortRetracementOk  = retShortWeeklyOk and retShortDailyOk and retShortEmaOk and retShortResistOk and retShortSweepOk

// Final long/short signals based on trade mode
bool longSignal  = false
bool shortSignal = false

if tradeMode == "Continuation"
    longSignal  := longContinuationOk
    shortSignal := shortContinuationOk
else if tradeMode == "Retracement"
    longSignal  := longRetracementOk
    shortSignal := shortRetracementOk
else
    // Both mode
    longSignal  := longContinuationOk or longRetracementOk
    shortSignal := shortContinuationOk or shortRetracementOk

// Kill zone gating
bool killZoneOk = useKillZones ? inAnyKZ : true

// --- Section 7: Trade Status Determination ---

if barstate.isconfirmed
    // Signal expiry check: reset if signal has been active too long
    if tradeStatus != NO_SETUP and not na(signalBar) and (bar_index - signalBar > signalExpiryBars)
        tradeStatus := NO_SETUP
        entryPrice  := na
        slPrice     := na
        tp1Price    := na
        tp2Price    := na
        signalBar   := na
        tp1Hit      := false
        tp2Source   := "Fixed RR"

    // Weekly close hold logic: extend signal expiry if weekly confirms direction
    if useWeeklyHoldLogic and tradeStatus != NO_SETUP and not na(signalBar)
        if tradeStatus == LONG_READY and weeklyClosedBullish
            signalBar := bar_index
        if tradeStatus == SHORT_READY and weeklyClosedBearish
            signalBar := bar_index

    // New signal generation (only in kill zones if enabled)
    if killZoneOk and longSignal
        tradeStatus := LONG_READY
        entryPrice  := close
        slPrice     := supportLevel - atrValue * atrMultiplier
        float risk  = close - slPrice
        tp1Price    := close + risk * rr1
        // Dynamic TP2 logic
        tp2Source   := "Fixed RR"
        float fixedTP2 = close + risk * rr2
        tp2Price    := fixedTP2
        if useDynamicTP and not na(weeklyResistanceZone) and weeklyResistanceZone > tp1Price
            tp2Price := weeklyResistanceZone
            tp2Source := "Weekly Zone"
        // Round number TP adjustment
        if useRoundNumberTP and not na(roundLevelAbove)
            if roundLevelAbove > tp1Price and roundLevelAbove < tp2Price
                tp2Price := roundLevelAbove
                tp2Source := tp2Source == "Weekly Zone" ? "Weekly Zone" : "Round Level"
        signalBar   := bar_index
        tp1Hit      := false
    else if killZoneOk and shortSignal
        tradeStatus := SHORT_READY
        entryPrice  := close
        slPrice     := resistanceLevel + atrValue * atrMultiplier
        float risk  = slPrice - close
        tp1Price    := close - risk * rr1
        // Dynamic TP2 logic
        tp2Source   := "Fixed RR"
        float fixedTP2 = close - risk * rr2
        tp2Price    := fixedTP2
        if useDynamicTP and not na(weeklySupportZone) and weeklySupportZone < tp1Price
            tp2Price := weeklySupportZone
            tp2Source := "Weekly Zone"
        // Round number TP adjustment
        if useRoundNumberTP and not na(roundLevelBelow)
            if roundLevelBelow < tp1Price and roundLevelBelow > tp2Price
                tp2Price := roundLevelBelow
                tp2Source := tp2Source == "Weekly Zone" ? "Weekly Zone" : "Round Level"
        signalBar   := bar_index
        tp1Hit      := false
    else if tradeStatus == NO_SETUP
        tradeStatus := NO_SETUP
        entryPrice  := na
        slPrice     := na
        tp1Price    := na
        tp2Price    := na
        tp2Source   := "Fixed RR"

// --- Section 7b: TP1 Hit Detection and Trailing Stop ---

// Check if TP1 has been hit while signal is active
if tradeStatus == LONG_READY and not na(tp1Price) and not tp1Hit
    if high >= tp1Price
        tp1Hit := true
        // Move SL to breakeven (entry price)
        slPrice := entryPrice

if tradeStatus == SHORT_READY and not na(tp1Price) and not tp1Hit
    if low <= tp1Price
        tp1Hit := true
        // Move SL to breakeven (entry price)
        slPrice := entryPrice

// Signal age calculation
int signalAge = (tradeStatus != NO_SETUP and not na(signalBar)) ? (bar_index - signalBar) : na

// --- Section 8: Weekly Structure Labels on Chart ---

var float prevDetectedWeeklyPH = na
var float prevDetectedWeeklyPL = na

if showStructureLabels
    // Detect new weekly pivot high
    if not na(weeklyPivotHigh) and (na(prevDetectedWeeklyPH) or weeklyPivotHigh != prevDetectedWeeklyPH)
        if not na(prevWeeklyPH)
            if weeklyPivotHigh > prevWeeklyPH
                label.new(bar_index, high, "HH", style=label.style_label_down, color=color.green, textcolor=color.white, size=size.small)
            else
                label.new(bar_index, high, "LH", style=label.style_label_down, color=color.red, textcolor=color.white, size=size.small)
        prevDetectedWeeklyPH := weeklyPivotHigh
    // Detect new weekly pivot low
    if not na(weeklyPivotLow) and (na(prevDetectedWeeklyPL) or weeklyPivotLow != prevDetectedWeeklyPL)
        if not na(prevWeeklyPL)
            if weeklyPivotLow > prevWeeklyPL
                label.new(bar_index, low, "HL", style=label.style_label_up, color=color.green, textcolor=color.white, size=size.small)
            else
                label.new(bar_index, low, "LL", style=label.style_label_up, color=color.red, textcolor=color.white, size=size.small)
        prevDetectedWeeklyPL := weeklyPivotLow

// --- Section 9: Dashboard ---

var table dashboard = table.new(position.top_right, 2, 25, bgcolor=color.new(color.black, 80), border_width=1, border_color=color.gray)

// Helper function for bias coloring
colorForBias(string bias) =>
    bias == BULLISH ? color.green : bias == BEARISH ? color.red : color.gray

// Weekly close color
string weeklyCloseText = weeklyClosedBullish ? "Bullish" : weeklyClosedBearish ? "Bearish" : "Neutral"
color weeklyCloseColor = weeklyClosedBullish ? color.green : weeklyClosedBearish ? color.red : color.gray

// Nearest round level for display
float displayRoundLevel = tradeStatus == SHORT_READY ? roundLevelBelow : roundLevelAbove

// Update dashboard on last bar
if barstate.islast
    // Row 0: Symbol
    table.cell(dashboard, 0, 0, "Symbol", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 0, syminfo.ticker, text_color=color.white, text_size=size.small)

    // Row 1: Timeframe
    table.cell(dashboard, 0, 1, "Timeframe", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 1, timeframe.period, text_color=color.white, text_size=size.small)

    // Row 2: Weekly Bias
    table.cell(dashboard, 0, 2, "Weekly Bias", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 2, weeklyBias, text_color=colorForBias(weeklyBias), text_size=size.small)

    // Row 3: 1W Structure
    table.cell(dashboard, 0, 3, "1W Structure", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 3, weeklyStructure, text_color=getStructureColor(weeklyStructure), text_size=size.small)

    // Row 4: 1D Structure
    table.cell(dashboard, 0, 4, "1D Structure", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 4, dailyStructure, text_color=getStructureColor(dailyStructure), text_size=size.small)

    // Row 5: 4H Structure
    table.cell(dashboard, 0, 5, "4H Structure", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 5, h4Structure, text_color=getStructureColor(h4Structure), text_size=size.small)

    // Row 6: Daily Alignment
    table.cell(dashboard, 0, 6, "Daily Alignment", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 6, dailyAlignment, text_color=colorForBias(dailyAlignment), text_size=size.small)

    // Row 7: EMA Status
    table.cell(dashboard, 0, 7, "EMA Status", text_color=color.white, text_size=size.small)
    string emaText = isAboveEma ? "Above" : "Below"
    color emaColor = isAboveEma ? color.green : color.red
    table.cell(dashboard, 1, 7, emaText, text_color=emaColor, text_size=size.small)

    // Row 8: Kill Zone
    table.cell(dashboard, 0, 8, "Kill Zone", text_color=color.white, text_size=size.small)
    color kzColor = killZoneStatus == "London" ? color.yellow : killZoneStatus == "NY" ? color.orange : killZoneStatus == "Disabled" ? color.gray : color.silver
    table.cell(dashboard, 1, 8, killZoneStatus, text_color=kzColor, text_size=size.small)

    // Row 9: Expectation
    table.cell(dashboard, 0, 9, "Expectation", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 9, trendExpectation, text_color=expectationColor, text_size=size.small)

    // Row 10: Weekly Close
    table.cell(dashboard, 0, 10, "Weekly Close", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 10, weeklyCloseText, text_color=weeklyCloseColor, text_size=size.small)

    // Row 11: Trade Mode
    table.cell(dashboard, 0, 11, "Trade Mode", text_color=color.white, text_size=size.small)
    color modeColor = tradeMode == "Continuation" ? color.blue : tradeMode == "Retracement" ? color.purple : color.teal
    table.cell(dashboard, 1, 11, tradeMode, text_color=modeColor, text_size=size.small)

    // Row 12: Nearest Support
    table.cell(dashboard, 0, 12, "Nearest S", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 12, not na(nearestSupport) ? str.tostring(nearestSupport, format.mintick) : "---", text_color=color.green, text_size=size.small)

    // Row 13: Nearest Resistance
    table.cell(dashboard, 0, 13, "Nearest R", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 13, not na(nearestResistance) ? str.tostring(nearestResistance, format.mintick) : "---", text_color=color.red, text_size=size.small)

    // Row 14: Liquidity Sweep (with volume status)
    table.cell(dashboard, 0, 14, "Liq. Sweep", text_color=color.white, text_size=size.small)
    string sweepText = sweepStatus == "None" ? "None" : sweepStatus + (sweepVolumeConfirmed ? " (Vol)" : " (No Vol)")
    color sweepColor = sweepStatus == BULLISH ? color.green : sweepStatus == BEARISH ? color.red : color.gray
    table.cell(dashboard, 1, 14, sweepText, text_color=sweepColor, text_size=size.small)

    // Row 15: Round Level
    table.cell(dashboard, 0, 15, "Round Level", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 15, not na(displayRoundLevel) ? str.tostring(displayRoundLevel, format.mintick) : "---", text_color=color.yellow, text_size=size.small)

    // Row 16: Entry
    table.cell(dashboard, 0, 16, "Entry", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 16, not na(entryPrice) ? str.tostring(entryPrice, format.mintick) : "---", text_color=color.white, text_size=size.small)

    // Row 17: Stop Loss
    table.cell(dashboard, 0, 17, "Stop Loss", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 17, not na(slPrice) ? str.tostring(slPrice, format.mintick) : "---", text_color=color.red, text_size=size.small)

    // Row 18: TP1
    table.cell(dashboard, 0, 18, "TP1", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 18, not na(tp1Price) ? str.tostring(tp1Price, format.mintick) : "---", text_color=color.green, text_size=size.small)

    // Row 19: TP2
    table.cell(dashboard, 0, 19, "TP2", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 19, not na(tp2Price) ? str.tostring(tp2Price, format.mintick) : "---", text_color=color.lime, text_size=size.small)

    // Row 20: TP2 Source
    table.cell(dashboard, 0, 20, "TP2 Source", text_color=color.white, text_size=size.small)
    color tp2SrcColor = tp2Source == "Weekly Zone" ? color.aqua : tp2Source == "Round Level" ? color.yellow : color.gray
    table.cell(dashboard, 1, 20, tp2Source, text_color=tp2SrcColor, text_size=size.small)

    // Row 21: RR
    table.cell(dashboard, 0, 21, "RR", text_color=color.white, text_size=size.small)
    string rrText = "---"
    if not na(entryPrice) and not na(slPrice) and math.abs(entryPrice - slPrice) > 0
        float risk = math.abs(entryPrice - slPrice)
        float reward = not na(tp1Price) ? math.abs(tp1Price - entryPrice) : 0.0
        rrText := str.tostring(reward / risk, "#.##") + "R"
    table.cell(dashboard, 1, 21, rrText, text_color=color.white, text_size=size.small)

    // Row 22: Signal Age
    table.cell(dashboard, 0, 22, "Signal Age", text_color=color.white, text_size=size.small)
    string ageText = not na(signalAge) ? str.tostring(signalAge) + " bars" : "---"
    color ageColor = not na(signalAge) ? (signalAge > signalExpiryBars - 3 ? color.orange : color.white) : color.gray
    table.cell(dashboard, 1, 22, ageText, text_color=ageColor, text_size=size.small)

    // Row 23: TP1 Status
    table.cell(dashboard, 0, 23, "TP1 Status", text_color=color.white, text_size=size.small)
    string tp1Text = tradeStatus == NO_SETUP ? "---" : (tp1Hit ? "TP1 Hit" : "Pending")
    color tp1Color = tp1Hit ? color.lime : (tradeStatus != NO_SETUP ? color.yellow : color.gray)
    table.cell(dashboard, 1, 23, tp1Text, text_color=tp1Color, text_size=size.small)

    // Row 24: Status
    table.cell(dashboard, 0, 24, "Status", text_color=color.white, text_size=size.small)
    string statusText = tradeStatus
    color statusColor = tradeStatus == LONG_READY ? color.green : tradeStatus == SHORT_READY ? color.red : color.gray
    if tp1Hit and tradeStatus != NO_SETUP
        statusText := "TP1 HIT - TRAIL"
        statusColor := color.lime
    table.cell(dashboard, 1, 24, statusText, text_color=statusColor, text_size=size.small)

// --- Section 10: Chart Visuals ---

// Plot EMA with dynamic color
emaPlotColor = close > emaValue ? color.green : color.red
plot(emaValue, "EMA", color=emaPlotColor, linewidth=2)

// Multi-level Support lines (up to 3, different styles and shades)
var line supportLine1 = na
var line supportLine2 = na
var line supportLine3 = na

// Multi-level Resistance lines (up to 3, different styles and shades)
var line resistLine1 = na
var line resistLine2 = na
var line resistLine3 = na

// Support line colors (green shades: most recent = brightest)
color supColor1 = color.green
color supColor2 = color.new(color.green, 40)
color supColor3 = color.new(color.green, 70)

// Resistance line colors (red shades: most recent = brightest)
color resColor1 = color.red
color resColor2 = color.new(color.red, 40)
color resColor3 = color.new(color.red, 70)

// Delete and redraw support levels
if not na(supportLine1)
    line.delete(supportLine1)
    supportLine1 := na
if not na(supportLine2)
    line.delete(supportLine2)
    supportLine2 := na
if not na(supportLine3)
    line.delete(supportLine3)
    supportLine3 := na

int supSize = array.size(supportLevels)
if supSize >= 1
    // Most recent = solid
    supportLine1 := line.new(bar_index - 1, array.get(supportLevels, supSize - 1), bar_index, array.get(supportLevels, supSize - 1), color=supColor1, style=line.style_solid, width=1, extend=extend.both)
if supSize >= 2
    // Second = dashed
    supportLine2 := line.new(bar_index - 1, array.get(supportLevels, supSize - 2), bar_index, array.get(supportLevels, supSize - 2), color=supColor2, style=line.style_dashed, width=1, extend=extend.both)
if supSize >= 3
    // Third = dotted
    supportLine3 := line.new(bar_index - 1, array.get(supportLevels, supSize - 3), bar_index, array.get(supportLevels, supSize - 3), color=supColor3, style=line.style_dotted, width=1, extend=extend.both)

// Delete and redraw resistance levels
if not na(resistLine1)
    line.delete(resistLine1)
    resistLine1 := na
if not na(resistLine2)
    line.delete(resistLine2)
    resistLine2 := na
if not na(resistLine3)
    line.delete(resistLine3)
    resistLine3 := na

int resSize = array.size(resistanceLevels)
if resSize >= 1
    // Most recent = solid
    resistLine1 := line.new(bar_index - 1, array.get(resistanceLevels, resSize - 1), bar_index, array.get(resistanceLevels, resSize - 1), color=resColor1, style=line.style_solid, width=1, extend=extend.both)
if resSize >= 2
    // Second = dashed
    resistLine2 := line.new(bar_index - 1, array.get(resistanceLevels, resSize - 2), bar_index, array.get(resistanceLevels, resSize - 2), color=resColor2, style=line.style_dashed, width=1, extend=extend.both)
if resSize >= 3
    // Third = dotted
    resistLine3 := line.new(bar_index - 1, array.get(resistanceLevels, resSize - 3), bar_index, array.get(resistanceLevels, resSize - 3), color=resColor3, style=line.style_dotted, width=1, extend=extend.both)

// Trade level lines and labels
var line entryLine = na
var line slLine    = na
var line tp1Line   = na
var line tp2Line   = na
var label tradeLbl = na

// Track previous status to detect changes
var string prevTradeStatus = NO_SETUP

// Delete old trade visuals when status changes
if tradeStatus != prevTradeStatus
    if not na(entryLine)
        line.delete(entryLine)
        entryLine := na
    if not na(slLine)
        line.delete(slLine)
        slLine := na
    if not na(tp1Line)
        line.delete(tp1Line)
        tp1Line := na
    if not na(tp2Line)
        line.delete(tp2Line)
        tp2Line := na
    if not na(tradeLbl)
        label.delete(tradeLbl)
        tradeLbl := na

// Draw new trade visuals
if tradeStatus == LONG_READY and not na(entryPrice) and not na(slPrice) and not na(tp1Price) and not na(tp2Price)
    if na(entryLine)
        entryLine := line.new(bar_index - 1, entryPrice, bar_index, entryPrice, color=color.white, style=line.style_solid, width=2, extend=extend.both)
        slLine    := line.new(bar_index - 1, slPrice, bar_index, slPrice, color=color.red, style=line.style_solid, width=1, extend=extend.both)
        tp1Line   := line.new(bar_index - 1, tp1Price, bar_index, tp1Price, color=color.green, style=line.style_solid, width=1, extend=extend.both)
        tp2Line   := line.new(bar_index - 1, tp2Price, bar_index, tp2Price, color=color.lime, style=line.style_solid, width=1, extend=extend.both)
        tradeLbl  := label.new(bar_index, entryPrice, "LONG READY", style=label.style_label_up, color=color.green, textcolor=color.white, size=size.normal)

if tradeStatus == SHORT_READY and not na(entryPrice) and not na(slPrice) and not na(tp1Price) and not na(tp2Price)
    if na(entryLine)
        entryLine := line.new(bar_index - 1, entryPrice, bar_index, entryPrice, color=color.white, style=line.style_solid, width=2, extend=extend.both)
        slLine    := line.new(bar_index - 1, slPrice, bar_index, slPrice, color=color.red, style=line.style_solid, width=1, extend=extend.both)
        tp1Line   := line.new(bar_index - 1, tp1Price, bar_index, tp1Price, color=color.green, style=line.style_solid, width=1, extend=extend.both)
        tp2Line   := line.new(bar_index - 1, tp2Price, bar_index, tp2Price, color=color.lime, style=line.style_solid, width=1, extend=extend.both)
        tradeLbl  := label.new(bar_index, entryPrice, "SHORT READY", style=label.style_label_down, color=color.red, textcolor=color.white, size=size.normal)

// Update SL line position when TP1 is hit (moved to breakeven)
if tp1Hit and not na(slLine) and not na(entryPrice)
    line.set_y1(slLine, entryPrice)
    line.set_y2(slLine, entryPrice)
    line.set_color(slLine, color.yellow)

// --- Section 11: Alert Conditions ---

// For alertcondition(), use [1] operator to compare with previous bar's value
alertcondition(tradeStatus == LONG_READY and tradeStatus[1] != LONG_READY, title="Long Ready", message="Swing Framework: LONG READY on {{ticker}} at {{close}}")
alertcondition(tradeStatus == SHORT_READY and tradeStatus[1] != SHORT_READY, title="Short Ready", message="Swing Framework: SHORT READY on {{ticker}} at {{close}}")
alertcondition(tradeStatus == NO_SETUP and tradeStatus[1] != NO_SETUP, title="Setup Cleared", message="Swing Framework: Setup cleared on {{ticker}}")

// Dynamic JSON alerts (use prevTradeStatus which still holds previous bar's value)
if tradeStatus == LONG_READY and prevTradeStatus != LONG_READY
    alert('{"ticker":"' + syminfo.ticker + '","signal":"LONG","mode":"' + tradeMode + '","entry":' + str.tostring(entryPrice) + ',"sl":' + str.tostring(slPrice) + ',"tp1":' + str.tostring(tp1Price) + ',"tp2":' + str.tostring(tp2Price) + ',"tp2_source":"' + tp2Source + '"}', alert.freq_once_per_bar)

if tradeStatus == SHORT_READY and prevTradeStatus != SHORT_READY
    alert('{"ticker":"' + syminfo.ticker + '","signal":"SHORT","mode":"' + tradeMode + '","entry":' + str.tostring(entryPrice) + ',"sl":' + str.tostring(slPrice) + ',"tp1":' + str.tostring(tp1Price) + ',"tp2":' + str.tostring(tp2Price) + ',"tp2_source":"' + tp2Source + '"}', alert.freq_once_per_bar)

// Update previous status tracker (AFTER alerts are evaluated)
prevTradeStatus := tradeStatus

// --- End of Script ---

// ============================================================================
// NOTES & LIMITATIONS
// ============================================================================
//
// HOW WEEKLY BIAS IS APPROXIMATED:
//   Weekly bias uses ta.pivothigh() and ta.pivotlow() on the weekly timeframe
//   with a configurable pivot length (htfPivotLength). The last two confirmed
//   pivot highs and lows are compared via ta.valuewhen():
//     - Higher High + Higher Low = Bullish (uptrend structure)
//     - Lower High + Lower Low = Bearish (downtrend structure)
//   When pivots are not yet available (na), the fallback compares weekly close
//   against a weekly EMA to approximate directional bias.
//
// HOW DAILY SHIFT IS DETECTED:
//   Daily alignment combines two conditions:
//     1. Price position relative to daily EMA (trend filter)
//     2. Pivot structure (HH/HL for bullish, LH/LL for bearish) OR price
//        breaking above/below the last confirmed daily pivot
//   Both conditions must agree for a directional alignment reading.
//   This helps filter out ranging/choppy periods.
//
// 4H STRUCTURE:
//   The 4H timeframe pivot detection uses the same htfPivotLength parameter
//   and ta.pivothigh()/ta.pivotlow() via request.security(). Structure is
//   displayed in the dashboard as HH+HL (bullish), LH+LL (bearish), or
//   mixed combinations for ranging markets.
//
// RETRACEMENT MODE:
//   The trader's actual strategy trades retracements within larger trends:
//     - Weekly bearish (LH+LL): BUY the expected retracement UP to resistance
//     - Weekly bullish (HH+HL): SELL the expected retracement DOWN to support
//   Retracement mode requires daily alignment to confirm the pullback direction
//   has begun before signaling. This is the key difference from continuation
//   mode which trades with the weekly trend direction.
//
// DYNAMIC TP (WEEKLY ZONE):
//   When enabled, TP2 targets the nearest weekly resistance zone (for longs)
//   or weekly support zone (for shorts) instead of a fixed R:R multiple.
//   Falls back to fixed R:R if the weekly zone is not available or does not
//   exceed TP1. TP1 always remains at the fixed R:R level.
//
// ROUND PSYCHOLOGICAL LEVEL TP:
//   When enabled, if a round psychological level (e.g., 77000 for BTC,
//   2400 for ETH, 150 for SOL) falls between TP1 and TP2, TP2 is adjusted
//   to that round level. The increment is price-dependent (1000/100/10/1/0.1).
//
// WEEKLY CANDLE CLOSE HOLD LOGIC:
//   When enabled, if an active LONG signal exists and the weekly candle closes
//   bullish, the signal expiry timer is reset (refreshed). Similarly for SHORT
//   with a bearish weekly close. This keeps valid signals alive when the weekly
//   confirms the trade direction. Counter-direction closes do not extend.
//
// TREND LEG EXPECTATION:
//   Analyzes where price sits relative to the weekly swing structure to
//   determine if the next move is likely a continuation or retracement.
//   Uses a 30% threshold from the extremes of the weekly PH-to-PL range.
//
// WEEKLY STRUCTURE LABELS:
//   When enabled, draws HH/HL/LH/LL labels on the chart whenever new weekly
//   pivots are confirmed. Green labels for bullish structure (HH, HL), red
//   labels for bearish structure (LH, LL). Only draws on new pivot detection.
//
// MULTI-LEVEL SUPPORT/RESISTANCE:
//   The indicator tracks the last 3 pivot highs and last 3 pivot lows on the
//   chart timeframe. These are plotted with different line styles:
//     - Most recent: solid line (full opacity)
//     - Second: dashed line (medium opacity)
//     - Third: dotted line (low opacity)
//   For trade logic, the nearest support below price and nearest resistance
//   above price are used. This provides more robust zone detection than a
//   single-level approach.
//
// KILL ZONE FILTERING:
//   When enabled, signals only fire during London (default 02:00-05:00 ET) or
//   New York (default 08:30-11:00 ET) sessions. This reduces noise during
//   low-volume off-hours. The timezone is configurable between New York,
//   London, and UTC.
//
// VOLUME CONFIRMATION FOR SWEEPS:
//   Liquidity sweep detection can optionally require that the sweep bar has
//   volume exceeding a configurable multiple (default 1.5x) of the 20-period
//   volume SMA. This filters out low-conviction sweeps that may be noise
//   rather than genuine institutional activity.
//
// SIGNAL EXPIRY:
//   Signals automatically expire after a configurable number of bars (default
//   10). This prevents stale signals from persisting when market conditions
//   have moved on. The dashboard shows signal age to help with timing.
//   The weekly hold logic can extend this timer when weekly closes confirm.
//
// TP1 HIT / TRAILING CONCEPT:
//   When price reaches the TP1 level after a signal fires, the indicator:
//     1. Marks TP1 as hit in the dashboard
//     2. Moves the stop loss line to breakeven (entry price)
//     3. Changes the status display to "TP1 HIT - TRAIL"
//   This represents the common practice of taking partial profit at TP1 and
//   trailing the remainder with a breakeven stop.
//
// ALERT SYSTEM:
//   The indicator provides both static alertcondition() calls (for
//   TradingView's built-in alert system) and dynamic alert() calls with
//   JSON payloads containing ticker, signal direction, trade mode, entry,
//   SL, TP1, TP2, and TP2 source. JSON alerts fire once per bar to avoid spam.
//
// DASHBOARD (25 ROWS):
//   The dashboard displays: Symbol, Timeframe, Weekly Bias, 1W Structure,
//   1D Structure, 4H Structure, Daily Alignment, EMA Status, Kill Zone,
//   Expectation, Weekly Close, Trade Mode, Nearest S, Nearest R, Liq. Sweep,
//   Round Level, Entry, Stop Loss, TP1, TP2, TP2 Source, RR, Signal Age,
//   TP1 Status, Status.
//
// LIMITATIONS:
//   - Weekly and daily pivots require sufficient history to form. The indicator
//     will show Neutral bias until enough data is available.
//   - Liquidity sweep detection is simplified: it checks if a single bar wicks
//     beyond support/resistance and closes back inside. Multi-bar sweeps or
//     accumulation patterns are not detected.
//   - The indicator does not manage actual trades. "LONG READY" and "SHORT READY"
//     are signal states, not automatic entries.
//   - The R:R calculation assumes the stop loss is placed at the exact
//     support/resistance level minus/plus ATR buffer. Actual fills may differ.
//   - Pine Script v5 does not have User Defined Types (UDTs), so state is
//     managed via individual var variables rather than structured types.
//   - Kill zone session times are approximate; they represent typical
//     high-volume windows but actual volatility may vary day to day.
//   - The trailing stop concept is visual only; no actual position management
//     or broker integration is performed.
//   - Dynamic TP depends on weekly pivots being available; new assets without
//     sufficient weekly history will fall back to fixed R:R.
//   - Round number TP is disabled by default as not all instruments benefit
//     equally from psychological level targeting.
//
// ============================================================================